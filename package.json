{
  "name": "aiqadam",
  "version": "0.0.0",
  "private": true,
  "description": "AI Qadam — multi-tenant community platform for AI engineers across Central Asia.",
  "homepage": "https://github.com/aiqadam/ai-qadam-platform",
  "repository": {
    "type": "git",
    "url": "https://github.com/aiqadam/ai-qadam-platform.git"
  },
  "license": "UNLICENSED",
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:bash": "bash scripts/run-bats.sh scripts/tests/*.bats",
    "lint": "biome check .",
    "fix": "biome check --write .",
    "format": "biome format --write .",
    "prepare": "husky || true",
    "arch:check": "tsx tools/architecture-check.ts",
    "gen:page": "tsx tools/gen/page.ts",
    "gen:cabinet": "tsx tools/gen/cabinet.ts",
    "ai:sync": "bash scripts/sync-ai-rules.sh",
    "uat:seed": "bash scripts/uat-seed.sh",
    "e2e:parity": "pnpm --filter @aiqadam/e2e e2e:parity",
    "cutover:repoint": "tsx scripts/cutover-authentik-repoint.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "bats": "^1.10.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "tsx": "^4.22.3",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "pnpm": {
    "overrides": {
      "tmp@<0.2.6": ">=0.2.6",
      "undici": ">=7.28.0",
      "multer": ">=2.2.0",
      "vite": ">=6.4.3",
      "js-yaml": ">=4.3.0",
      "linkify-it": ">=5.0.2",
      "svgo": ">=4.0.2",
      "fast-uri": ">=3.1.4",
      "sharp": ">=0.35.0",
      "next": ">=16.2.11"
    }
  }
}
