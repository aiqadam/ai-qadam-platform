# --- Agentic workflow task directories ---
# NOTE: Task outputs are committed for audit trail. Do NOT uncomment.
# Old task directories can be manually swept/archived when repo grows.
# If you uncomment this, the audit trail breaks - every workflow must be able to
# reference its completed task artifacts via git history.
# .copilot/tasks/

# --- Dependencies ----------------------------------------------------------
node_modules/
.pnpm-store/
.npm/
.yarn/

# --- Build / output artifacts ---------------------------------------------
dist/
build/
out/
.turbo/
.astro/
.output/
.next/
.nest/
*.tsbuildinfo

# --- Python (apps/bot, scripts) -------------------------------------------
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- Environment / secrets ------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
*.crt
secrets/

# --- Editor / IDE ----------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~

# --- OS junk --------------------------------------------------------------
.DS_Store
Thumbs.db
*.bak
*.orig
*.rej

# --- Logs -----------------------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# --- Test / coverage ------------------------------------------------------
coverage/
.nyc_output/

# --- Caches ---------------------------------------------------------------
.cache/
*.cache

# --- Claude Code per-developer settings -----------------------------------
# settings.local.json is per-developer (always gitignored).
# settings.json is also gitignored for now since it has accumulated
# session-specific permission entries; will be re-introduced as a
# project-shared baseline once we curate it.
.claude/settings.json
.claude/settings.local.json

# --- Claude Code transcripts / state --------------------------------------
.claude/projects/

# --- Agent session memory (per-developer / per-session; never committed) ---
# Created by the Copilot / Claude session memory tools. Ephemeral notes
# about how a specific session resolved a problem; not project state.
.memories/

# --- Coolify / VM-side files (never in repo) ------------------------------
# (Coolify state lives at /data/coolify on the host, never here.
# Listed for awareness if anyone ever copies one into the repo.)
coolify.env*
coolify-env-backup*.txt

# --- Local credential files (never in repo) --------------------------------
infrastructure/telegram.md

# --- UAT session runtime artifacts (never in repo) -------------------------
# These are generated by scripts/uat-env-setup.sh and scripts/uat-seed.sh
# against a *specific local* Authentik instance. The token + OIDC client
# secret are tied to a single container's database — committing them would
# hand a new dev dead credentials that silently 401 against their own fresh
# Authentik. The reproducible tooling that creates them (.copilot/bootstrap-
# oidc.sh, .copilot/oidc-provider-body.json, .copilot/check-*.sh) IS tracked.
.copilot/oidc-setup-token
.copilot/oidc-bootstrap.env
.copilot/discovery.json
.copilot/uat-env-setup.log
