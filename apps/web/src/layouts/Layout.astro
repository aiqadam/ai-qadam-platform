---
import '../styles/globals.css';
import Nav from '../components/Nav.astro';
import AppFooter from '../components/AppFooter.astro';

interface Props {
  title?: string;
  description?: string;
  // M5.1 SEO props: each is optional, sensible defaults below. Pages that
  // want a per-page social card or canonical override pass overrides.
  ogType?: 'website' | 'article' | 'event';
  ogImage?: string;
  canonical?: string;
}

const {
  title = 'AI Qadam',
  description = 'Multi-tenant community platform for AI engineers across Central Asia.',
  ogType = 'website',
  ogImage,
} = Astro.props;

// Absolute URL helpers for OG / canonical. Astro.url contains the build-
// time URL for prerendered pages (host is typically the dev server) and
// the real request URL for SSR pages. We pick the most useful origin:
//   - explicit `canonical` prop wins
//   - else Astro.url if host looks like an aiqadam.org subdomain (SSR)
//   - else Astro.site (apex, configured in astro.config.mjs)
// Note: per-tenant subdomains all serve the same prerendered bundle, so
// prerendered pages canonicalize to apex. That's fine — Google treats
// the apex as the authoritative copy and the subdomains as locale
// variants of the same content. Override per-page when a tenant-aware
// canonical matters.
const site = Astro.site ?? new URL('https://aiqadam.org/');
const requestUrl = Astro.url ?? site;
const requestIsAiqadam = requestUrl.host.endsWith('aiqadam.org');
const origin = requestIsAiqadam ? `${requestUrl.protocol}//${requestUrl.host}` : site.origin;
const canonicalUrl =
  Astro.props.canonical ?? (requestIsAiqadam ? requestUrl.toString() : `${origin}${requestUrl.pathname}`);
// Default OG image is the brand mark. Per-page overrides (event detail,
// etc.) pass an absolute or origin-rooted URL. Pre-generated per-event
// social cards are a M5.1-followup; for now everyone shares the mark.
const ogImageUrl = ogImage
  ? ogImage.startsWith('http')
    ? ogImage
    : `${origin}${ogImage}`
  : `${origin}/brand/aiqadam-mark.png`;

// SSR auth hand-off. Astro middleware resolves `Astro.locals.auth` once
// per request (calls /auth/refresh + /auth/me server-side, propagates the
// rotated cookie). We serialise the result into window.__AIQADAM_AUTH__
// so React islands can render their authenticated UI on first paint
// without firing their own /auth/refresh — that's what created the
// island-vs-island race that occasionally killed sessions and leaked
// stale RBAC. See middleware.ts header for the full rationale.
//
// We only inject the blob when middleware actually ran (locals.auth is
// defined — null OR object). For PRERENDERED pages the middleware is
// skipped at build time and locals.auth stays undefined; we omit the
// script so auth-bootstrap.ts's helper falls back to the network path
// (same behavior as before this PR). If we always injected, a
// build-time `null` would tell islands "you're anonymous" for every
// signed-in visitor on a prerendered page.
//
// JSON.stringify + </script> escaping — Astro's `set:html` renders raw
// (no entity encoding) so we have to neutralise the close-tag manually.
const ssrAuth = Astro.locals.auth;
const ssrAuthInject = ssrAuth !== undefined;
const ssrAuthJson = ssrAuthInject
  ? JSON.stringify(ssrAuth).replace(/</g, '\\u003c')
  : null;
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/png" href="/brand/aiqadam-mark.png" />

    <!-- Open Graph (Facebook / LinkedIn / Telegram / Slack / Discord) -->
    <meta property="og:site_name" content="AI Qadam" />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card (Twitter / X) -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <!-- Plausible Analytics (M5.0). data-domain matches the site configured
         in the dashboard at analytics.aiqadam.org. Self-hosted, cookieless,
         ~1KB gzip — safe to ship before any consent UI. -->
    <script
      is:inline
      defer
      data-domain="aiqadam.org"
      src="https://analytics.aiqadam.org/js/script.js"
    ></script>
    <slot name="head" />
    {ssrAuthInject && <script is:inline set:html={`window.__AIQADAM_AUTH__ = ${ssrAuthJson};`} />}
  </head>
  <body class="min-h-screen antialiased">
    <Nav />
    <slot />
    <!-- Site-wide footer (ISS-UAT-009-4 / wf-20260704-fix-077). Rendered
         after the page slot so every short page — including /me AnonView —
         gets the same layout-completeness surface as apps/web-next. The
         attribution-capture script below still runs after paint. -->
    <AppFooter />
    <!-- F-S3.9 attribution capture: resolves ?ref= + stashes UTM into
         long-lived cookies the registration submit reads. Idempotent;
         no-op when no params present. Runs after page paint. -->
    <script>
      import { captureLandingAttribution } from '../lib/attribution';
      void captureLandingAttribution();
    </script>
  </body>
</html>
