---
// Always-visible top nav per design screen s1-1 (`.app-nav`). Three clusters:
//   - Brand mark + wordmark
//   - Center nav links (Events / Leaderboard / Account-or-Sign-in)
//   - Right cluster: country switcher + locale switcher
//
// Auth-conditional rendering of the right-most nav slot:
//   - signed in   → "Account" → /me
//   - signed out  → "Sign in" CTA → /auth/sign-in?next=…
//
// 2026-05-25: switched from a syntactic cookie-presence check to the
// SERVER-VERIFIED auth state in `Astro.locals.auth`, populated by the
// SSR middleware. Eliminates the "Nav says Sign in" / "body says signed
// in as X" inconsistency that happened when an island /refresh race
// revoked the family + cleared the cookie before SSR ran. Trusts the
// API's confirmation, not cookie syntax.
//
// Country detection happens client-side from `window.location.hostname` so
// this component stays prerender-safe (no per-request data needed). Locale
// resolution still uses the cookie + Accept-Language header per F3 — for
// SSR pages it's per-request, for prerendered ones it falls back to default.

import { LOCALE_COOKIE, SUPPORTED_LOCALES, getLocale, makeT } from '../lib/i18n';
import { NavAccountMenu } from './NavAccountMenu';

const locale = getLocale(Astro);
const t = makeT(locale);

// On prerendered pages `Astro.locals.auth` is undefined (middleware
// doesn't run for static output). Anon fallback in that case — a
// signed-in user on a prerendered page sees the "Sign in" CTA briefly
// and gets silent-SSO'd back when they click it.
const signedInHint = Astro.locals.auth?.me != null;

const currentPath = `${Astro.url.pathname}${Astro.url.search}`;
const signInHref = `/auth/sign-in?next=${encodeURIComponent(currentPath)}`;

const COUNTRY_CODES = ['uz', 'kz', 'tj', 'global'] as const;
const COUNTRY_FLAGS: Record<(typeof COUNTRY_CODES)[number], string> = {
  uz: '🇺🇿',
  kz: '🇰🇿',
  tj: '🇹🇯',
  global: '🌐',
};
---

<header
  style="position: sticky; top: 0; z-index: 50; backdrop-filter: blur(12px); background: color-mix(in oklch, var(--background) 85%, transparent); border-bottom: 1px solid var(--border);"
>
  <div
    style="max-width: 1180px; margin: 0 auto; padding: 0 32px; display: flex; align-items: center; height: 56px; gap: 16px;"
  >
    <a
      href="/"
      style="display: flex; align-items: center; gap: 10px; text-decoration: none; color: inherit;"
    >
      <img src="/brand/aiqadam-mark.png" alt="" style="width: 24px; height: 24px; object-fit: contain;" />
      <span style="font-family: var(--font-display); font-weight: 600; font-size: 15px; letter-spacing: -0.01em;">
        AI <span style="color: var(--primary);">Qadam</span>
      </span>
    </a>

    <nav
      style="display: flex; align-items: center; gap: 4px; margin-left: 16px; flex: 1;"
    >
      <a href="/events" class="app-nav-link">{t('nav.events')}</a>
      <a href="/leaderboard" class="app-nav-link">{t('nav.leaderboard')}</a>
      {signedInHint ? (
        <a href="/me" class="app-nav-link">{t('nav.account')}</a>
      ) : (
        <a href={signInHref} class="btn btn-sm btn-primary" style="text-decoration: none; margin-left: 8px;">
          {t('nav.sign_in')}
        </a>
      )}
    </nav>

    <div style="display: flex; align-items: center; gap: 8px;">
      <select
        id="country-switcher"
        aria-label={t('country.label')}
        style="background: var(--card); color: var(--foreground); border: 1px solid var(--border); border-radius: 6px; padding: 5px 8px; font-size: 12px; font-family: var(--font-mono);"
      >
        {COUNTRY_CODES.map((code) => (
          <option value={code}>{COUNTRY_FLAGS[code]} {t(`country.${code}`)}</option>
        ))}
      </select>

      <select
        id="locale-switcher"
        aria-label={t('locale.label')}
        style="background: var(--card); color: var(--foreground); border: 1px solid var(--border); border-radius: 6px; padding: 5px 8px; font-size: 12px; font-family: var(--font-mono);"
      >
        {SUPPORTED_LOCALES.map((code) => (
          <option value={code} selected={code === locale}>{t(`locale.${code}`)}</option>
        ))}
      </select>

      <NavAccountMenu
        client:load
        t={{
          signed_in_as: t('nav.signed_in_as'),
          sign_out: t('actions.sign_out'),
          account_menu_aria: t('nav.account_menu_aria'),
          workspace: t('nav.workspace'),
          engineering_deck: t('nav.engineering_deck'),
        }}
      />
    </div>
  </div>
</header>

<style is:global>
  .app-nav-link {
    display: inline-flex;
    align-items: center;
    height: 30px;
    padding: 0 10px;
    font-size: 13px;
    color: var(--muted-foreground);
    text-decoration: none;
    border-radius: 6px;
  }
  .app-nav-link:hover {
    color: var(--foreground);
    background: color-mix(in oklch, var(--muted) 60%, transparent);
  }
  /* Inline-mounted hydration islands inside flex/grid containers must
     pass through to their parent's layout — otherwise their children
     stop participating in the parent's gap + alignment. */
  astro-island {
    display: contents;
  }
</style>

<script is:inline define:vars={{ cookieName: LOCALE_COOKIE, countryCodes: COUNTRY_CODES }}>
  // Country switcher: detect current country from hostname, navigate to
  // sibling subdomain on change. In production hostnames look like
  // <code>.aiqadam.org or aiqadam.org (apex). Local dev (localhost,
  // 127.0.0.1) is no-op — there's no DNS for subdomains.
  const cs = document.getElementById('country-switcher');
  if (cs) {
    const hostname = window.location.hostname.toLowerCase();
    const firstLabel = hostname.split('.')[0] ?? '';
    const current = countryCodes.includes(firstLabel) ? firstLabel : 'uz';
    for (const opt of cs.options) {
      opt.selected = opt.value === current;
    }
    cs.addEventListener('change', (e) => {
      const code = e.target.value;
      if (hostname.endsWith('aiqadam.org')) {
        window.location.href = `https://${code}.aiqadam.org${window.location.pathname}${window.location.search}`;
      }
    });
  }

  // Locale switcher: write cookie, full reload so SSR pages re-render in
  // the new language and prerendered pages pick it up on next nav.
  const ls = document.getElementById('locale-switcher');
  if (ls) {
    ls.addEventListener('change', (e) => {
      const next = e.target.value;
      document.cookie = `${cookieName}=${next}; path=/; max-age=31536000; samesite=lax`;
      window.location.reload();
    });
  }
</script>
