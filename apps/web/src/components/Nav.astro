---
// Always-visible top nav. Auth state is determined client-side per ADR-0016
// — see AuthGate.tsx. The "Sign in" / "Sign out" affordances live on /me
// rather than here, since the nav is rendered server-side and would need
// client-side hydration just to flip between the two.
//
// PR A1 (country homepage) will replace this with the designed `.app-nav`
// from portal-reference.html s1-1. F3 adds i18n primitives + a tiny locale
// switcher; A1 inherits both into the proper design.

import { LOCALE_COOKIE, SUPPORTED_LOCALES, getLocale, makeT } from '../lib/i18n';

const locale = getLocale(Astro);
const t = makeT(locale);
---

<nav style="border-bottom: 1px solid var(--border); background: var(--background);">
  <div class="mx-auto flex max-w-3xl items-center justify-between px-6 py-3">
    <a href="/" style="font-family: var(--font-display); font-weight: 600; font-size: 14px; color: var(--foreground);">AI Qadam</a>
    <div class="flex items-center gap-4 text-sm" style="color: var(--muted-foreground);">
      <a href="/" style="color: inherit;">{t('nav.home')}</a>
      <a href="/events" style="color: inherit;">{t('nav.events')}</a>
      <a href="/leaderboard" style="color: inherit;">{t('nav.leaderboard')}</a>
      <a href="/me" style="color: inherit;">{t('nav.account')}</a>
      <select
        id="locale-switcher"
        aria-label={t('locale.label')}
        style="background: var(--card); color: var(--foreground); border: 1px solid var(--border); border-radius: 6px; padding: 4px 8px; font-size: 12px; font-family: var(--font-mono);"
      >
        {SUPPORTED_LOCALES.map((code) => (
          <option value={code} selected={code === locale}>{t(`locale.${code}`)}</option>
        ))}
      </select>
    </div>
  </div>
</nav>

<script define:vars={{ cookieName: LOCALE_COOKIE }}>
  const sel = document.getElementById('locale-switcher');
  if (sel) {
    sel.addEventListener('change', (e) => {
      const next = e.target.value;
      // path=/, 1 year, lax (server-side reads it on next nav).
      document.cookie = `${cookieName}=${next}; path=/; max-age=31536000; samesite=lax`;
      window.location.reload();
    });
  }
</script>
