---
import Layout from '../layouts/Layout.astro';
import { fetchMarketingAssets } from '../lib/cms';

// Public press / media kit page. F-S0.9b (Tier-2 wire-up): wired to
// Directus `marketing_assets` per ADR-0025 for the asset classes that
// live there (press-headshot, fact-sheet, quarterly-digest,
// press-coverage). Tier 1 stays in git — logos + palette are still
// hardcoded below.
//
// Each Tier-2 section gracefully degrades to the "coming soon" empty
// state per UX §1.4 when 0 approved+public assets exist for that
// category. The page renders today identically to the prior Potemkin
// (no assets uploaded yet); the moment Viktor uploads + approves the
// first headshot / fact-sheet / digest / coverage row, the relevant
// section lights up.
//
// design-system/ tokens locked — only existing classes and CSS
// variables. SSG-friendly except for the marketing_assets fetch which
// runs at request time (Directus state changes; we want the page fresh).

const description =
  'AI Qadam media kit — logo, brand assets, founder + COO bios, fact sheet, and press contact for journalists, partners, and event organizers.';

// Tier 1 assets (per ADR-0025): logos / favicons / brand mark stay in
// git at apps/web/public/brand/. Edited only by engineers via PR.
const logos = [
  { file: '/brand/aiqadam-logo.png', label: 'Full logo (PNG)' },
  { file: '/brand/aiqadam-logo-transparent.png', label: 'Full logo, transparent (PNG)' },
  { file: '/brand/aiqadam-mark.png', label: 'Mark only (PNG)' },
];

// Tier 2 assets from Directus marketing_assets. Each call returns an
// empty array on Directus failure / no approved assets — the empty
// branches in the markup below handle that with UX §1.4 copy.
const [headshots, factSheets, quarterlyDigests, pressCoverage] = await Promise.all([
  fetchMarketingAssets({ category: 'press-headshot', limit: 8 }),
  fetchMarketingAssets({ category: 'fact-sheet', limit: 1 }),
  fetchMarketingAssets({ category: 'quarterly-digest', limit: 4 }),
  fetchMarketingAssets({ category: 'press-coverage', limit: 12 }),
]);

// Match headshots to leadership by title-prefix. Uploader names assets
// like "Binali Rustamov — founder headshot" so a startsWith match is
// robust; if no match, the placeholder card renders instead. Sort in
// the cms helper is -date_created, so a newer rev replaces an older
// one automatically.
function findHeadshot(forName: string): (typeof headshots)[0] | undefined {
  return headshots.find((h) => h.title.toLowerCase().startsWith(forName.toLowerCase()));
}
const binaliHeadshot = findHeadshot('Binali');
const viktorHeadshot = findHeadshot('Viktor');
const latestFactSheet = factSheets[0];

// Brand color palette — exact values from design-system/tokens.css. Surfaced
// here so journalists / sponsors can use brand-correct colors in artwork
// without asking. Light-mode primary is the "circuit teal" the design
// system locks; dark-mode is brighter for the dark surface.
const palette = [
  {
    name: 'Brand teal (light)',
    css: 'oklch(0.58 0.10 192)',
    role: 'Primary on light surfaces',
  },
  {
    name: 'Brand teal (dark)',
    css: 'oklch(0.70 0.105 192)',
    role: 'Primary on dark surfaces (default theme)',
  },
];
---

<Layout
  title="Press & media kit — AI Qadam"
  description={description}
  ogType="website"
>
  <main style="max-width: 1180px; margin: 0 auto;">
    <!-- Hero / boilerplate. The opening sentence is the locked one-line
         from playbook §1: lifts the burden off journalists who otherwise
         paraphrase from the about page. -->
    <section style="padding: 64px 48px 32px;">
      <p
        class="section-eyebrow"
        style="margin-bottom: 16px; font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--muted-foreground);"
      >
        Press kit
      </p>
      <h1
        style="font-family: var(--font-display); font-weight: 600; font-size: 42px; line-height: 1.15; margin: 0 0 16px; max-width: 780px;"
      >
        AI Qadam — for journalists, partners, and event organizers
      </h1>
      <p style="font-size: 17px; line-height: 1.55; max-width: 760px; color: var(--muted-foreground); margin: 0;">
        Founded by Binali Rustamov in 2026, AI Qadam is run by a distributed team of
        country leads with a working community across all three Central Asian republics.
        Below: brand assets, founder bios, a fact sheet, and how to reach us.
      </p>
    </section>

    <!-- Press contact. Lives near the top because that's the surface
         journalists came for. -->
    <section style="padding: 32px 48px; border-top: 1px solid var(--border);">
      <p
        class="section-eyebrow"
        style="margin-bottom: 12px; font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--muted-foreground);"
      >
        Press contact
      </p>
      <p style="font-size: 17px; margin: 0 0 8px;">
        Email <a href="mailto:press@aiqadam.org" style="color: var(--primary);">press@aiqadam.org</a>.
        Reaches Binali within one business day; faster on weekdays.
      </p>
      <p style="font-size: 14px; color: var(--muted-foreground); margin: 0;">
        Embargo requests, interview asks, and fact-checks all welcome here.
      </p>
    </section>

    <!-- Founders / leadership. Per playbook §15.4 + UX §2.1 role
         definitions. Headshots load from /press-kit/ once Viktor drops
         them in; until then the page renders with role + sentence and a
         placeholder block instead of a broken image. -->
    <section style="padding: 32px 48px; border-top: 1px solid var(--border);">
      <p
        class="section-eyebrow"
        style="margin-bottom: 16px; font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--muted-foreground);"
      >
        Leadership
      </p>
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
        <article
          style="padding: 24px; border: 1px solid var(--border); border-radius: 12px; background: var(--card); display: flex; flex-direction: column; gap: 14px;"
        >
          {binaliHeadshot ? (
            <a
              href={binaliHeadshot.fileUrl}
              download
              style="display: block; height: 200px; border-radius: 8px; background: var(--muted); overflow: hidden;"
            >
              <img
                src={binaliHeadshot.thumbnailUrl ?? binaliHeadshot.fileUrl}
                alt={binaliHeadshot.title}
                style="width: 100%; height: 100%; object-fit: cover; display: block;"
                loading="lazy"
              />
            </a>
          ) : (
            <div
              aria-hidden="true"
              style="height: 200px; border-radius: 8px; background: var(--muted); display: flex; align-items: center; justify-content: center; font-family: var(--font-mono); font-size: 11px; color: var(--muted-foreground); letter-spacing: 0.06em; text-transform: uppercase;"
            >
              Headshot — coming soon
            </div>
          )}
          <div>
            <h2 style="font-family: var(--font-display); font-weight: 600; font-size: 22px; margin: 0 0 4px;">
              Binali Rustamov
            </h2>
            <p
              style="font-family: var(--font-mono); font-size: 12px; color: var(--muted-foreground); margin: 0 0 12px; letter-spacing: 0.04em;"
            >
              Founder
            </p>
            <p style="font-size: 15px; line-height: 1.55; color: var(--card-foreground); margin: 0;">
              Voice for vision posts, big-deal welcomes, founder essays, and
              quarterly digest sign-off. Speaks for AI Qadam on milestone
              announcements and press attribution.
            </p>
          </div>
        </article>
        <article
          style="padding: 24px; border: 1px solid var(--border); border-radius: 12px; background: var(--card); display: flex; flex-direction: column; gap: 14px;"
        >
          {viktorHeadshot ? (
            <a
              href={viktorHeadshot.fileUrl}
              download
              style="display: block; height: 200px; border-radius: 8px; background: var(--muted); overflow: hidden;"
            >
              <img
                src={viktorHeadshot.thumbnailUrl ?? viktorHeadshot.fileUrl}
                alt={viktorHeadshot.title}
                style="width: 100%; height: 100%; object-fit: cover; display: block;"
                loading="lazy"
              />
            </a>
          ) : (
            <div
              aria-hidden="true"
              style="height: 200px; border-radius: 8px; background: var(--muted); display: flex; align-items: center; justify-content: center; font-family: var(--font-mono); font-size: 11px; color: var(--muted-foreground); letter-spacing: 0.06em; text-transform: uppercase;"
            >
              Headshot — coming soon
            </div>
          )}
          <div>
            <h2 style="font-family: var(--font-display); font-weight: 600; font-size: 22px; margin: 0 0 4px;">
              Viktor Drukker
            </h2>
            <p
              style="font-family: var(--font-mono); font-size: 12px; color: var(--muted-foreground); margin: 0 0 12px; letter-spacing: 0.04em;"
            >
              COO + Head of Vibe Code &amp; Platform Operations
            </p>
            <p style="font-size: 15px; line-height: 1.55; color: var(--card-foreground); margin: 0;">
              Voice for platform updates, ops emails, build-in-public content,
              and operator-side communications. Reviews every AI-generated
              brand asset before it ships.
            </p>
          </div>
        </article>
      </div>
    </section>

    <!-- Logo pack. Existing PNGs in /brand/ ship today; the SVG variants
         listed in playbook §15.3 (light/dark/wordmark) land as Viktor
         produces them. The `download` attribute hints the browser to save
         rather than navigate. -->
    <section style="padding: 32px 48px; border-top: 1px solid var(--border);">
      <p
        class="section-eyebrow"
        style="margin-bottom: 16px; font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--muted-foreground);"
      >
        Logo
      </p>
      <p style="font-size: 14px; color: var(--muted-foreground); margin: 0 0 20px; max-width: 640px;">
        Use the mark or the full logo. Don't recolor, distort, or recreate.
        SVG variants and the press pack (zip) ship as we produce them — for
        now, PNG covers the common cases.
      </p>
      <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px;">
        {logos.map((logo) => (
          <a
            href={logo.file}
            download
            style="display: flex; flex-direction: column; gap: 10px; padding: 16px; border: 1px solid var(--border); border-radius: 10px; background: var(--card); text-decoration: none; color: inherit;"
          >
            <div style="height: 120px; display: flex; align-items: center; justify-content: center; background: var(--background); border-radius: 6px;">
              <img
                src={logo.file}
                alt={logo.label}
                style="max-height: 88px; max-width: 100%;"
                loading="lazy"
              />
            </div>
            <span style="font-size: 13px; color: var(--card-foreground);">
              Download {logo.label}
            </span>
          </a>
        ))}
      </div>
    </section>

    <!-- Brand color palette. Programmatically rendered from tokens; the
         OKLCH string is authoritative for production work. Hex equivalents
         omitted on purpose — OKLCH is the source of truth and any sRGB
         clamp belongs in the designer's tool, not in our docs. -->
    <section style="padding: 32px 48px; border-top: 1px solid var(--border);">
      <p
        class="section-eyebrow"
        style="margin-bottom: 16px; font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--muted-foreground);"
      >
        Brand colors
      </p>
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
        {palette.map((swatch) => (
          <div
            style="display: flex; gap: 16px; align-items: center; padding: 16px; border: 1px solid var(--border); border-radius: 10px; background: var(--card);"
          >
            <div
              aria-hidden="true"
              style={`width: 72px; height: 72px; border-radius: 10px; background: ${swatch.css}; flex: 0 0 auto;`}
            ></div>
            <div>
              <p
                style="font-family: var(--font-display); font-weight: 600; font-size: 16px; margin: 0 0 4px;"
              >
                {swatch.name}
              </p>
              <p
                style="font-family: var(--font-mono); font-size: 12px; color: var(--muted-foreground); margin: 0 0 4px;"
              >
                {swatch.css}
              </p>
              <p style="font-size: 13px; color: var(--card-foreground); margin: 0;">
                {swatch.role}
              </p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Fact sheet. Single-PDF download. Lives at /press-kit/fact-sheet.pdf
         once Viktor produces it; until then we render an empty state so
         journalists know to email instead. -->
    <section style="padding: 32px 48px; border-top: 1px solid var(--border);">
      <p
        class="section-eyebrow"
        style="margin-bottom: 16px; font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--muted-foreground);"
      >
        Fact sheet
      </p>
      {latestFactSheet ? (
        <article
          style="padding: 24px; border: 1px solid var(--border); border-radius: 12px; background: var(--card);"
        >
          <p style="font-size: 15px; margin: 0 0 12px;">
            {latestFactSheet.title}
          </p>
          {latestFactSheet.description && (
            <p style="font-size: 14px; color: var(--muted-foreground); margin: 0 0 16px;">
              {latestFactSheet.description}
            </p>
          )}
          <a
            href={latestFactSheet.fileUrl}
            download
            style="display: inline-block; padding: 10px 16px; border-radius: 8px; background: var(--primary); color: var(--primary-foreground); font-size: 14px; text-decoration: none;"
          >
            Download fact sheet
          </a>
        </article>
      ) : (
        <article
          style="padding: 24px; border: 1px dashed var(--border); border-radius: 12px; background: var(--card);"
        >
          <p style="font-size: 15px; margin: 0 0 8px;">
            One-page PDF — mission, history, numbers — coming with our first
            quarterly digest.
          </p>
          <p style="font-size: 14px; color: var(--muted-foreground); margin: 0;">
            Need the numbers sooner? Email <a href="mailto:press@aiqadam.org" style="color: var(--primary);">press@aiqadam.org</a>.
          </p>
        </article>
      )}
    </section>

    <!-- Quarterly community reports. Reads from marketing_assets where
         category=quarterly-digest AND status=approved AND visibility=public.
         Empty state per UX §1.4 until the first issue lands. -->
    <section style="padding: 32px 48px; border-top: 1px solid var(--border);">
      <p
        class="section-eyebrow"
        style="margin-bottom: 16px; font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--muted-foreground);"
      >
        Community reports
      </p>
      {quarterlyDigests.length > 0 ? (
        <ul style="list-style: none; padding: 0; margin: 0; display: grid; gap: 10px;">
          {quarterlyDigests.map((digest) => (
            <li>
              <a
                href={digest.fileUrl}
                download
                style="display: flex; justify-content: space-between; gap: 16px; padding: 16px 20px; border: 1px solid var(--border); border-radius: 10px; background: var(--card); text-decoration: none; color: inherit;"
              >
                <span style="font-size: 15px;">{digest.title}</span>
                <span style="font-family: var(--font-mono); font-size: 12px; color: var(--muted-foreground);">
                  Download
                </span>
              </a>
            </li>
          ))}
        </ul>
      ) : (
        <article
          style="padding: 24px; border: 1px dashed var(--border); border-radius: 12px; background: var(--card);"
        >
          <p style="font-size: 15px; margin: 0 0 8px;">
            Quarterly digest — numbers, milestones, member stories — lands here
            when issue one publishes.
          </p>
          <p style="font-size: 14px; color: var(--muted-foreground); margin: 0;">
            Sponsors receive the digest directly; the public archive opens with
            the second issue.
          </p>
        </article>
      )}
    </section>

    <!-- Past press coverage. Reads from marketing_assets where
         category=press-coverage AND status=approved AND visibility=public.
         Each row's description is the publication + date (free-form). -->
    <section style="padding: 32px 48px 64px; border-top: 1px solid var(--border);">
      <p
        class="section-eyebrow"
        style="margin-bottom: 16px; font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--muted-foreground);"
      >
        Press coverage
      </p>
      {pressCoverage.length > 0 ? (
        <ul style="list-style: none; padding: 0; margin: 0; display: grid; gap: 10px;">
          {pressCoverage.map((item) => (
            <li
              style="padding: 16px 20px; border: 1px solid var(--border); border-radius: 10px; background: var(--card);"
            >
              <p style="font-size: 15px; margin: 0 0 6px;">
                <a href={item.fileUrl} style="color: var(--primary);">
                  {item.title}
                </a>
              </p>
              {item.description && (
                <p style="font-size: 13px; color: var(--muted-foreground); margin: 0;">
                  {item.description}
                </p>
              )}
            </li>
          ))}
        </ul>
      ) : (
        <article
          style="padding: 24px; border: 1px dashed var(--border); border-radius: 12px; background: var(--card);"
        >
          <p style="font-size: 15px; margin: 0 0 8px;">
            We've kept our heads down. First coverage lands when it lands —
            we'll link it here.
          </p>
          <p style="font-size: 14px; color: var(--muted-foreground); margin: 0;">
            Writing about us? Email <a href="mailto:press@aiqadam.org" style="color: var(--primary);">press@aiqadam.org</a> and we'll
            add the link once it's live.
          </p>
        </article>
      )}
    </section>
  </main>
</Layout>
