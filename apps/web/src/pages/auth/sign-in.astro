---
// /auth/sign-in is the public sign-in entry referenced from header CTAs,
// /me, /events/[id] gates, etc. It used to render an interstitial
// "Continue to sign in" button. That step is friction: every CTA on the
// site already says "Sign in" — the next thing the user expects is a
// password form, not a second button.
//
// We now 302 straight to /api/v1/auth/login, which 302s to Authentik's
// branded login form. Result: one click → password form. The page
// itself has no UI; it exists only so internal links to /auth/sign-in
// keep working.

export const prerender = false;

const url = new URL(Astro.request.url);
const rawNext = url.searchParams.get('next') ?? '/';
const safeNext = rawNext.startsWith('/') && !rawNext.startsWith('//') ? rawNext : '/';
return Astro.redirect(`/api/v1/auth/login?next=${encodeURIComponent(safeNext)}`);
---
