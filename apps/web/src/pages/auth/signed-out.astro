---
import Layout from '../../layouts/Layout.astro';

export const prerender = false;
---

<Layout title="Signed out · AI Qadam">
  <main
    style="max-width: 420px; margin: 0 auto; padding: 80px 24px; display: flex; flex-direction: column; gap: 24px; text-align: center;"
  >
    <h1
      style="font-family: var(--font-display); font-weight: 600; font-size: 32px; letter-spacing: -0.025em; margin: 0;"
    >
      Signed out
    </h1>
    <p style="font-size: 14px; color: var(--muted-foreground); margin: 0;">
      Your session has been revoked. Stolen access tokens stop working immediately.
    </p>
    <div style="display: flex; gap: 12px; justify-content: center;">
      <a href="/auth/sign-in" class="btn btn-primary" style="text-decoration: none;">Sign in again</a>
      <a href="/" class="btn btn-outline" style="text-decoration: none;">Home</a>
    </div>
  </main>
</Layout>
