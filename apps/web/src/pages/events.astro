---
import EventsGrid from '../components/EventsGrid.astro';
import EventsTimeline from '../components/EventsTimeline.astro';
import { LeadCaptureForm } from '../components/LeadCaptureForm';
import Layout from '../layouts/Layout.astro';
import { fetchPastEvents, fetchUpcomingEvents } from '../lib/cms';
import { getLocale, makeT } from '../lib/i18n';

// Events index per design screen s1-2. Two views toggled via ?view=:
//   - timeline (default): events grouped by month with .tl-item dots
//   - grid: 3-col grid of .event-card
//
// F-WebU14 adds three filter knobs on top:
//   - ?tab=upcoming|past — toggles the dataset (past tab no longer disabled)
//   - ?format=meetup|workshop|hackathon|conference|online — server-side filter
//   - ?q=<text> — case-insensitive title contains, max 80 chars
// All three are honored at the Directus query layer (no client filtering),
// so the URL is the source of truth and SEO sees real filtered results.
export const prerender = false;

const url = new URL(Astro.request.url);
const view = url.searchParams.get('view') === 'grid' ? 'grid' : 'timeline';
const tab = url.searchParams.get('tab') === 'past' ? 'past' : 'upcoming';
const rawFormat = url.searchParams.get('format');
const FORMATS = ['meetup', 'workshop', 'hackathon', 'conference', 'online'] as const;
type FormatKey = (typeof FORMATS)[number];
const format: FormatKey | null = (FORMATS as readonly string[]).includes(rawFormat ?? '')
  ? (rawFormat as FormatKey)
  : null;
const q = (url.searchParams.get('q') ?? '').trim().slice(0, 80);

const locale = getLocale(Astro);
const t = makeT(locale);
const events =
  tab === 'past'
    ? await fetchPastEvents(Astro.request, { format, q })
    : await fetchUpcomingEvents(Astro.request, { format, q });

// F-WebU14 — preserves any unrelated query params (e.g. utm_*) when
// flipping one knob. Pass {key: null} to drop a knob from the URL.
function withParams(updates: Record<string, string | null>): string {
  const next = new URLSearchParams(url.searchParams);
  for (const [k, v] of Object.entries(updates)) {
    if (v === null || v === '') next.delete(k);
    else next.set(k, v);
  }
  const qs = next.toString();
  return qs ? `/events?${qs}` : '/events';
}

const tabBase =
  'display: inline-flex; align-items: center; gap: 6px; padding: 6px 10px; border-radius: 6px; font-size: 12px; font-family: var(--font-mono); letter-spacing: 0.04em; text-decoration: none; cursor: pointer; border: 0; background: transparent;';
const tabActiveStyle = `${tabBase} background: var(--muted); color: var(--foreground);`;
const tabInactiveStyle = `${tabBase} color: var(--muted-foreground);`;

const filterChipBase =
  'display: inline-flex; align-items: center; padding: 6px 12px; border-radius: 999px; font-size: 12px; line-height: 1; text-decoration: none; border: 1px solid var(--border); cursor: pointer;';
const filterChipActive = `${filterChipBase} background: var(--primary); color: var(--primary-foreground); border-color: var(--primary);`;
const filterChipInactive = `${filterChipBase} background: var(--card); color: var(--muted-foreground);`;
---

<Layout title={`${t('nav.events')} · AI Qadam`}>
  <main style="max-width: 1180px; margin: 0 auto; padding: 40px 48px;">
    <div style="margin-bottom: 28px;">
      <h1
        style="font-family: var(--font-display); font-weight: 600; font-size: 36px; letter-spacing: -0.025em; margin: 0 0 6px;"
      >
        {t('events_index.title')}
      </h1>
      <p style="font-size: 14px; color: var(--muted-foreground); margin: 0;">
        {t('events_index.subtitle', { count: events.length })}
      </p>
    </div>

    <form
      method="get"
      action="/events"
      style="display: flex; gap: 8px; margin-bottom: 16px;"
    >
      <input type="hidden" name="tab" value={tab} />
      <input type="hidden" name="view" value={view} />
      {format && <input type="hidden" name="format" value={format} />}
      <input
        type="search"
        name="q"
        value={q}
        placeholder={t('events_index.search_placeholder')}
        aria-label={t('events_index.search_placeholder')}
        class="input"
        style="flex: 1; max-width: 480px;"
        maxlength="80"
      />
      <button type="submit" class="btn btn-sm btn-outline">
        {t('events_index.search_button')}
      </button>
      {q && (
        <a
          href={withParams({ q: null })}
          class="btn btn-sm btn-ghost"
          aria-label={t('events_index.search_clear')}
        >
          {t('events_index.search_clear')}
        </a>
      )}
    </form>

    <div style="display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 16px;">
      <a href={withParams({ format: null })} style={format == null ? filterChipActive : filterChipInactive}>
        {t('events_index.filter_all')}
      </a>
      {FORMATS.map((f) => (
        <a
          href={withParams({ format: f })}
          style={format === f ? filterChipActive : filterChipInactive}
        >
          {t(`events_index.filter_${f}`)}
        </a>
      ))}
    </div>

    <div
      style="display: flex; align-items: center; gap: 16px; padding: 12px 0; border-bottom: 1px solid var(--border); margin-bottom: 24px;"
    >
      <div style="display: inline-flex; gap: 4px;">
        <a
          href={withParams({ tab: null })}
          style={tab === 'upcoming' ? tabActiveStyle : tabInactiveStyle}
        >
          {t('events_index.tab_upcoming')}
          {tab === 'upcoming' && (
            <span class="count" style="font-family: var(--font-mono); font-size: 10px; opacity: 0.7;">
              {events.length}
            </span>
          )}
        </a>
        <a
          href={withParams({ tab: 'past' })}
          style={tab === 'past' ? tabActiveStyle : tabInactiveStyle}
        >
          {t('events_index.tab_past')}
          {tab === 'past' && (
            <span class="count" style="font-family: var(--font-mono); font-size: 10px; opacity: 0.7;">
              {events.length}
            </span>
          )}
        </a>
      </div>

      <div
        style="margin-left: auto; display: inline-flex; border: 1px solid var(--border); border-radius: 8px; padding: 2px;"
      >
        <a
          href={withParams({ view: null })}
          style={view === 'timeline'
            ? 'display: inline-flex; align-items: center; gap: 6px; padding: 4px 10px; border-radius: 6px; background: var(--muted); color: var(--foreground); font-size: 12px; text-decoration: none;'
            : 'display: inline-flex; align-items: center; gap: 6px; padding: 4px 10px; border-radius: 6px; color: var(--muted-foreground); font-size: 12px; text-decoration: none;'}
        >
          {t('events_index.view_timeline')}
        </a>
        <a
          href={withParams({ view: 'grid' })}
          style={view === 'grid'
            ? 'display: inline-flex; align-items: center; gap: 6px; padding: 4px 10px; border-radius: 6px; background: var(--muted); color: var(--foreground); font-size: 12px; text-decoration: none;'
            : 'display: inline-flex; align-items: center; gap: 6px; padding: 4px 10px; border-radius: 6px; color: var(--muted-foreground); font-size: 12px; text-decoration: none;'}
        >
          {t('events_index.view_grid')}
        </a>
      </div>
    </div>

    {events.length === 0 ? (
      <div class="empty-state" style="margin: 32px 0;">
        <div class="empty-icon" aria-hidden="true">🔍</div>
        <p class="empty-heading">{t('events_index.empty_title')}</p>
        <p class="empty-desc">
          {q || format
            ? t('events_index.empty_filtered_body')
            : tab === 'past'
              ? t('events_index.empty_past_body')
              : t('events_index.empty_upcoming_body')}
        </p>
      </div>
    ) : view === 'timeline' ? (
      <EventsTimeline events={events} locale={locale} />
    ) : (
      <EventsGrid events={events} locale={locale} />
    )}

    <section style="margin-top: 64px; padding-top: 48px; border-top: 1px solid var(--border);">
      <div style="max-width: 540px; margin: 0 auto;">
        <LeadCaptureForm client:load />
      </div>
    </section>
  </main>
</Layout>
