---
import Layout from '../layouts/Layout.astro';
import { fetchEventCountForCountry } from '../lib/cms';
import { getLocale, makeT } from '../lib/i18n';

// Splash for visitors whose Cloudflare-detected country isn't one of the
// three we serve, or who explicitly land on global.aiqadam.org. Three
// country tiles, one click each. SSR so locale resolution (cookie +
// Accept-Language) works per request — without prerender:false, the
// build emits "Astro.request.headers not available on prerendered pages"
// since getLocale reads the Accept-Language header.
//
// F-WebU18 — adds a per-country events-run count under each tile so the
// page surfaces real activity (vs. just three generic descriptions).
// Counts come from the same Directus aggregate as the homepage stat
// strip; failures degrade to "—" silently.
export const prerender = false;

const locale = getLocale(Astro);
const t = makeT(locale);

const COUNTRIES = [
  { code: 'uz', flag: '🇺🇿', host: 'uz.aiqadam.org', desc: t('global.uz_desc') },
  { code: 'kz', flag: '🇰🇿', host: 'kz.aiqadam.org', desc: t('global.kz_desc') },
  { code: 'tj', flag: '🇹🇯', host: 'tj.aiqadam.org', desc: t('global.tj_desc') },
] as const;

const countsByCountry = await Promise.all(
  COUNTRIES.map(async (c) => ({ code: c.code, count: await fetchEventCountForCountry(c.code) })),
);
const eventsCountMap = new Map(countsByCountry.map((r) => [r.code, r.count]));
---

<Layout title="AI Qadam — Central Asia" description="Pick your country.">
  <main
    style="max-width: 880px; margin: 0 auto; padding: 80px 32px; display: flex; flex-direction: column; align-items: center; gap: 48px; text-align: center;"
  >
    <div>
      <h1 style="font-family: var(--font-display); font-weight: 600; font-size: 56px; letter-spacing: -0.03em; margin: 0 0 12px;">
        AI <span style="color: var(--primary);">Qadam</span>
      </h1>
      <p style="font-size: 17px; color: var(--muted-foreground); margin: 0 0 6px;">
        {t('global.tagline')}
      </p>
      <p style="font-family: var(--font-mono); font-size: 12px; color: var(--muted-foreground); letter-spacing: 0.06em; text-transform: uppercase; margin: 0;">
        {t('global.subtitle')}
      </p>
    </div>

    <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; width: 100%;">
      {COUNTRIES.map((c) => {
        const eventsRun = eventsCountMap.get(c.code) ?? 0;
        return (
          <a
            href={`https://${c.host}/`}
            style="display: flex; flex-direction: column; gap: 12px; padding: 24px; border: 1px solid var(--border); border-radius: 12px; background: var(--card); text-decoration: none; color: inherit; text-align: left; transition: border-color 150ms;"
            onmouseover="this.style.borderColor='color-mix(in oklch, var(--primary) 60%, var(--border))'"
            onmouseout="this.style.borderColor='var(--border)'"
          >
            <div style="display: flex; align-items: center; gap: 10px;">
              <span style="font-size: 28px; line-height: 1;">{c.flag}</span>
              <span style="font-family: var(--font-display); font-weight: 600; font-size: 18px;">{t(`country.${c.code}`)}</span>
            </div>
            <p style="font-size: 13px; color: var(--muted-foreground); line-height: 1.5; margin: 0;">{c.desc}</p>
            <p
              style="font-family: var(--font-mono); font-size: 11px; color: var(--muted-foreground); letter-spacing: 0.04em; margin: 0;"
            >
              {eventsRun > 0
                ? t('global.stat_events_run', { count: eventsRun })
                : t('global.stat_events_zero')}
            </p>
            <span style="font-family: var(--font-mono); font-size: 11px; color: var(--primary); letter-spacing: 0.08em; text-transform: uppercase; margin-top: auto;">
              {t('global.browse')} →
            </span>
          </a>
        );
      })}
    </div>

    <p style="font-size: 12px; color: var(--muted-foreground); max-width: 560px; line-height: 1.6; margin: 0;">
      {t('global.note')}
    </p>
  </main>
</Layout>
