---
import { AdminUsersTable } from '../../../components/AdminUsersTable';
import AdminShell from '../../../layouts/AdminShell.astro';

export const prerender = false;
---

<AdminShell title="Admin · Users · AI Qadam" active="users">
  <header style="margin-bottom: 24px;">
    <h1
      style="font-family: var(--font-display); font-weight: 600; font-size: 32px; letter-spacing: -0.025em; margin: 0 0 4px;"
    >
      Users
    </h1>
    <p style="font-size: 13px; color: var(--muted-foreground); margin: 0;">
      Role assignments for all signed-in members. Super-admin only.
    </p>
  </header>
  <AdminUsersTable client:load />
</AdminShell>
