---
import OnboardingForm from '../components/OnboardingForm';
import Layout from '../layouts/Layout.astro';

// F-S2.7 (ADR-0035) + F-S2.8.2 — public invitee landing page. No auth —
// the token IS the credential. The OnboardingForm island walks the
// invitee through three steps: password+AUP → destination Gmail +
// Cloudflare verification poll → Resend key reveal + Gmail Send-as
// instructions.

export const prerender = true;
---

<Layout
  title="Welcome to AI Qadam · Operator onboarding"
  description="Activate your operator account: set your password, then set up email forwarding + sending."
>
  <main style="max-width: 640px; margin: 0 auto; padding: 64px 32px;">
    <OnboardingForm client:load />
  </main>
</Layout>

<style is:global>
  /* F-S2.8.2 — spinner used by OnboardingForm's polling + finalizing
     steps. Global so the React island can reference it without
     module-scoping. */
  @keyframes aiqadam-spin {
    to {
      transform: rotate(360deg);
    }
  }
</style>
