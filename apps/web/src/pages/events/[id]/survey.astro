---
import FormRenderer from '../../../components/FormRenderer';
import Layout from '../../../layouts/Layout.astro';
import { fetchEventSurvey, fetchSurveyEventContext } from '../../../lib/forms-api';

// Post-event survey page for a specific event.
//
// Picks up the form attached via `events.post_event_survey_form` (PR-A
// schema) and renders it with an event-context header above so the
// respondent sees which event they're giving feedback on.
//
// Dynamic-per-event content (event header, speakers list) is spliced
// in at render time — NOT in the operator-built form schema. The form
// template stays event-agnostic + reusable across all events.
//
// URL conventions:
//   /events/{slug}/survey         — operator-friendly URL
//   /events/{uuid}/survey         — uuid fallback (when slug is null)
//
// When no in-house form is attached → 404; bot may still render the
// external `events.feedback_survey_url` button (#322).
//
// PR-D9 — event context (title, speakers) is fetched via the bot's
// telegram API rather than anonymous Directus reads, because
// event_speakers + speakers + directus_users do NOT grant public
// Directus read. fetchSurveyEventContext wraps the existing public
// route through the authenticated API container.

export const prerender = false;

const { id } = Astro.params as { id: string };

// Form lookup is required (404 if missing); event context is
// best-effort — we render the form even if it fails.
const [form, eventContext] = await Promise.all([
  fetchEventSurvey(Astro.request, id),
  fetchSurveyEventContext(Astro.request, id).catch(() => null),
]);

if (!form) {
  return new Response('No survey attached to this event', { status: 404 });
}
---

<Layout
  title={`${form.title} · AI Qadam`}
  description={form.description ?? 'Post-event feedback — your input shapes the next one.'}
>
  <main style="max-width: 640px; margin: 0 auto; padding: 80px 32px;">
    <FormRenderer form={form} eventId={id} eventContext={eventContext} client:load />
  </main>
</Layout>
