---
import EventShareButtons from '../../components/EventShareButtons';
import { RegistrationSidebar } from '../../components/RegistrationSidebar';
import Layout from '../../layouts/Layout.astro';
import { fetchEvent, fetchEventMaterials, fetchEventPhotos, fetchEventSpeakers, fetchEventSponsors } from '../../lib/cms';
import { getLocale, makeT } from '../../lib/i18n';

// Event detail page per design screen s1-3 (desktop) / s1-4 (mobile).
//
// F-WebU8 — restructured into four fixed tabs (Upcoming / Live /
// Finished / Forum). Tab strip and stage-content surfaces are always
// present; only the default selection is computed from event timing.
// Tabs are driven by ?tab= so the URL is deep-linkable and SSR only
// renders the active content. Sidebar (Register + Share) is cross-tab.
//
// Prior slices preserved:
//   F-S3.10-a/b — hero/venue/agenda/visibility schema + render
//   F-WebU1     — external_links pills
//   F-WebU2     — OSM lat/lng iframe
//   F-WebU3     — event_materials section
//   F-WebU4     — inline YouTube/Vimeo recording embeds
export const prerender = false;

const VALID_TABS = ['upcoming', 'live', 'finished', 'forum'] as const;
type Tab = (typeof VALID_TABS)[number];

const { id } = Astro.params as { id: string };
const event = await fetchEvent(Astro.request, id);

if (!event) {
  return Astro.redirect('/events', 302);
}

// members_only / invite_only: render the gate body and skip the data
// payload. v1 uses the refresh cookie as the signed-in hint — its
// presence means the API issued a session; absence means anonymous.
const signedInHint = Astro.cookies.get('aiqadam-refresh')?.value !== undefined;
const isGated = (event.visibilityScope === 'members_only' || event.visibilityScope === 'invite_only') && !signedInHint;

const speakers = isGated ? [] : await fetchEventSpeakers(event.id);
const confirmedSpeakers = speakers.filter((s) => s.status === 'confirmed');
const allMaterials = isGated ? [] : await fetchEventMaterials(event.id);
const photos = isGated ? [] : await fetchEventPhotos(event.id);
const sponsors = isGated ? [] : await fetchEventSponsors(event.id);

// F-WebU4 — detect YouTube / Vimeo URLs and turn them into privacy-
// friendly embed URLs (youtube-nocookie.com so no tracking cookie is
// set until the user hits Play). Anything else returns null and the
// material falls back to a click-through pill in the Materials list.
function recordingEmbedSrc(url: string): string | null {
  let parsed: URL;
  try {
    parsed = new URL(url);
  } catch {
    return null;
  }
  const host = parsed.hostname.toLowerCase();
  if (host === 'youtu.be') {
    const ytId = parsed.pathname.slice(1).split('/')[0] ?? '';
    return /^[\w-]{6,}$/.test(ytId) ? `https://www.youtube-nocookie.com/embed/${ytId}` : null;
  }
  if (host === 'youtube.com' || host.endsWith('.youtube.com')) {
    const v = parsed.searchParams.get('v');
    if (v && /^[\w-]{6,}$/.test(v)) return `https://www.youtube-nocookie.com/embed/${v}`;
    const segs = parsed.pathname.split('/').filter(Boolean);
    if ((segs[0] === 'embed' || segs[0] === 'shorts') && segs[1] && /^[\w-]{6,}$/.test(segs[1])) {
      return `https://www.youtube-nocookie.com/embed/${segs[1]}`;
    }
  }
  if (host === 'vimeo.com' || host.endsWith('.vimeo.com')) {
    const m = parsed.pathname.match(/^\/(\d+)/);
    if (m?.[1]) return `https://player.vimeo.com/video/${m[1]}`;
  }
  return null;
}

const recordings = allMaterials
  .filter((m) => m.kind === 'recording' && m.url != null && recordingEmbedSrc(m.url) != null)
  .map((m) => ({ ...m, embedSrc: recordingEmbedSrc(m.url ?? '') as string }));
const recordingIds = new Set(recordings.map((r) => r.id));
const materials = allMaterials.filter((m) => !recordingIds.has(m.id));

const locale = getLocale(Astro);
const t = makeT(locale);

const FORMAT_LABEL: Record<string, string> = {
  meetup: 'MEETUP',
  workshop: 'WORKSHOP',
  hackathon: 'HACKATHON',
  conference: 'CONFERENCE',
  online: 'ONLINE',
};

const fullDate = new Date(event.startsAt).toLocaleDateString('en-US', {
  weekday: 'long',
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
const startTime = new Date(event.startsAt).toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit', hour12: false });
const endTime = new Date(event.endsAt).toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit', hour12: false });

// short_description is the social-card-friendly variant (≤300 chars,
// no markdown). Fall back to the first 300 chars of description so old
// events still get a non-empty OG preview.
const ogDescription = event.shortDescription?.trim() || event.description.slice(0, 300);

// M5.1 — JSON-LD Event schema for Google rich results + LinkedIn previews.
const origin = `${Astro.url.protocol}//${Astro.url.host}`;
const eventUrl = `${origin}/events/${event.id}`;
const isOnline = event.format === 'online' || (!event.venue && !event.location);
const placeName = event.venue ?? event.location ?? null;
const placeAddress = event.address ?? event.location ?? null;
const eventJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Event',
  name: event.title,
  description: ogDescription,
  startDate: event.startsAt,
  endDate: event.endsAt,
  eventStatus: 'https://schema.org/EventScheduled',
  eventAttendanceMode: isOnline
    ? 'https://schema.org/OnlineEventAttendanceMode'
    : 'https://schema.org/OfflineEventAttendanceMode',
  url: eventUrl,
  organizer: {
    '@type': 'Organization',
    name: 'AI Qadam',
    url: origin,
  },
  ...(placeName && !isOnline
    ? {
        location: {
          '@type': 'Place',
          name: placeName,
          ...(placeAddress ? { address: placeAddress } : {}),
        },
      }
    : {
        location: {
          '@type': 'VirtualLocation',
          url: eventUrl,
        },
      }),
  ...(event.heroImageUrl ? { image: [event.heroImageUrl] } : {}),
};

// Minimal markdown-ish renderer for agenda: split on blank lines into
// blocks, then on \n into lines. `- ` becomes a list bullet. Bold/italic
// are not rendered. Full markdown is overkill for what operators put in
// an agenda block; if it grows we'll swap in `marked`.
function renderAgenda(md: string): string {
  const blocks = md.split(/\n\s*\n/);
  const escapeHtml = (s: string) =>
    s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  return blocks
    .map((block) => {
      const lines = block.split('\n').map((l) => l.trim()).filter(Boolean);
      if (lines.length === 0) return '';
      if (lines.every((l) => l.startsWith('- '))) {
        return `<ul style="margin: 0 0 12px; padding-left: 20px;">${lines
          .map((l) => `<li>${escapeHtml(l.slice(2))}</li>`)
          .join('')}</ul>`;
      }
      return `<p style="margin: 0 0 12px;">${lines.map(escapeHtml).join('<br />')}</p>`;
    })
    .filter(Boolean)
    .join('');
}
const agendaHtml = event.agendaMd ? renderAgenda(event.agendaMd) : null;
const recapHtml = event.recapMd ? renderAgenda(event.recapMd) : null;
const hasFinishedContent = recordings.length > 0 || photos.length > 0 || recapHtml !== null;

// F-WebU10 — Live tab: if an operator has pasted a YouTube / Vimeo URL
// we embed it inline (same nocookie variant as Recordings); any other
// http(s) URL renders as a click-through Join button. Null = no stream
// connected, empty-state message.
const livestreamUrl = event.livestreamUrl?.trim() || null;
const livestreamEmbedSrc = livestreamUrl ? recordingEmbedSrc(livestreamUrl) : null;

// F-WebU2 — OpenStreetMap embed. Renders only when both coordinates
// are set; the fallback is the existing map_url click-through.
const lat = event.latitude;
const lng = event.longitude;
const hasCoords = lat != null && lng != null;
const mapEmbedSrc = hasCoords
  ? `https://www.openstreetmap.org/export/embed.html?bbox=${lng - 0.005},${lat - 0.005},${lng + 0.005},${lat + 0.005}&layer=mapnik&marker=${lat},${lng}`
  : null;

// F-WebU8 — auto-generated Google + Yandex Maps deep-links. OSM tiles
// occasionally mis-render specific venues (e.g. IT Park Tashkent points
// at the city centre instead of Mirzo-Ulug'bek district); operators
// don't pick a provider — we generate all three from whatever data is
// available, prefer coordinates, fall back to free-text address.
const addressQuery = (event.address ?? event.venue ?? event.location ?? '').trim();
const externalMaps: { google: string; yandex: string } | null = (() => {
  if (hasCoords) {
    return {
      google: `https://www.google.com/maps/search/?api=1&query=${lat},${lng}`,
      yandex: `https://yandex.com/maps/?ll=${lng},${lat}&z=17&pt=${lng},${lat},pm2rdm`,
    };
  }
  if (addressQuery.length === 0) return null;
  const enc = encodeURIComponent(addressQuery);
  return {
    google: `https://www.google.com/maps/search/?api=1&query=${enc}`,
    yandex: `https://yandex.com/maps/?text=${enc}`,
  };
})();

// F-S5.4 — generated OG card. Cache-busted by `v` so a speaker_added or
// metadata edit invalidates every scraper's cached preview.
const cacheBuster = event.updatedAt ? Date.parse(event.updatedAt) : Date.parse(event.startsAt);
const isPubliclyShareable = !event.visibilityScope || event.visibilityScope === 'public';
const ogCardUrl = isPubliclyShareable
  ? `${origin}/events/${event.id}/og-card.png?v=${cacheBuster}`
  : (event.heroImageUrl ?? null);

const layoutProps = {
  title: `${event.title} · AI Qadam`,
  description: ogDescription,
  ogType: 'event' as const,
  canonical: eventUrl,
  ...(ogCardUrl ? { ogImage: ogCardUrl } : {}),
};

// F-WebU8 — tab routing. Validate the ?tab= param against the closed
// set; pick a sensible default from the event's clock relative to
// (starts_at, ends_at). Fully empty content (no recordings on a past
// event, no livestream URL) still falls back to upcoming-style empty
// states so the page never looks broken.
const tabParam = Astro.url.searchParams.get('tab');
const tabRequested: Tab | null = tabParam && (VALID_TABS as readonly string[]).includes(tabParam)
  ? (tabParam as Tab)
  : null;
const now = Date.now();
const startsAtMs = Date.parse(event.startsAt);
const endsAtMs = Date.parse(event.endsAt);
const defaultTab: Tab =
  now >= endsAtMs ? 'finished' : now >= startsAtMs ? 'live' : 'upcoming';
const activeTab: Tab = tabRequested ?? defaultTab;

const eventBasePath = `/events/${event.id}`;
function tabHref(tab: Tab): string {
  return tab === defaultTab && !tabRequested ? eventBasePath : `${eventBasePath}?tab=${tab}`;
}
---

<Layout {...layoutProps}>
  <script slot="head" is:inline type="application/ld+json" set:html={JSON.stringify(eventJsonLd)} />
  <main>
    <div style="border-bottom: 1px solid var(--border);">
      <div style="max-width: 1180px; margin: 0 auto; padding: 16px 32px;">
        <a
          href="/events"
          style="display: inline-flex; align-items: center; gap: 6px; font-size: 13px; color: var(--muted-foreground); text-decoration: none;"
        >
          ← {t('event_detail.back')}
        </a>
      </div>
    </div>

    {event.heroImageUrl ? (
      <div
        style={`position: relative; height: 320px; overflow: hidden; border-bottom: 1px solid var(--border); background-image: url(${event.heroImageUrl}); background-size: cover; background-position: center;`}
      >
        <div style="position: absolute; inset: 0; background: linear-gradient(180deg, rgba(0,0,0,0.1) 0%, rgba(0,0,0,0.6) 100%);"></div>
        <div style="position: absolute; top: 20px; left: 40px; display: flex; gap: 8px;">
          <span class="badge mono" style="background: color-mix(in oklch, var(--background) 70%, transparent); backdrop-filter: blur(4px);">
            {FORMAT_LABEL[event.format] ?? event.format.toUpperCase()}
          </span>
        </div>
        <div style="position: absolute; bottom: 30px; left: 40px; right: 40px; max-width: 1100px; margin: 0 auto;">
          <h1
            style="font-family: var(--font-display); font-weight: 600; font-size: 40px; line-height: 1.05; letter-spacing: -0.03em; margin: 0; max-width: 760px; color: white; text-shadow: 0 2px 16px rgba(0,0,0,0.5);"
          >
            {event.title}
          </h1>
        </div>
      </div>
    ) : (
      <div
        style="position: relative; height: 280px; overflow: hidden; border-bottom: 1px solid var(--border); background: radial-gradient(ellipse at top right, color-mix(in oklch, var(--primary) 50%, var(--background)) 0%, color-mix(in oklch, var(--primary) 10%, var(--background)) 60%, var(--background) 100%);"
      >
        <div style="position: absolute; top: 20px; left: 40px; display: flex; gap: 8px;">
          <span class="badge mono" style="background: color-mix(in oklch, var(--background) 70%, transparent); backdrop-filter: blur(4px);">
            {FORMAT_LABEL[event.format] ?? event.format.toUpperCase()}
          </span>
        </div>
        <div style="position: absolute; bottom: 30px; left: 40px; right: 40px; max-width: 1100px; margin: 0 auto;">
          <h1
            style="font-family: var(--font-display); font-weight: 600; font-size: 40px; line-height: 1.05; letter-spacing: -0.03em; margin: 0; max-width: 760px;"
          >
            {event.title}
          </h1>
        </div>
      </div>
    )}

    {isGated ? (
      <div style="max-width: 720px; margin: 64px auto; padding: 32px; text-align: center;">
        <h2 style="font-family: var(--font-display); font-weight: 600; font-size: 22px; margin: 0 0 12px;">
          {t('event_detail.members_only_title')}
        </h2>
        <p style="color: var(--muted-foreground); font-size: 15px; line-height: 1.6; margin: 0 0 24px;">
          {t('event_detail.members_only_body')}
        </p>
        <a
          href={`/auth/sign-in?next=${encodeURIComponent(`/events/${event.id}`)}`}
          class="btn btn-primary"
          style="display: inline-block;"
        >
          {t('nav.sign_in')}
        </a>
      </div>
    ) : (
      <div style="max-width: 1180px; margin: 0 auto; padding: 24px 32px 32px;">
        <div class="tabs" role="tablist" aria-label={t('event_detail.tabs_label')}>
          {VALID_TABS.map((tab) => (
            <a
              class:list={['tab', { active: activeTab === tab }]}
              role="tab"
              aria-selected={activeTab === tab ? 'true' : 'false'}
              href={tabHref(tab)}
            >
              {t(`event_detail.tab_${tab}`)}
            </a>
          ))}
        </div>

        <div
          style="padding-top: 24px; display: grid; grid-template-columns: minmax(0, 1fr) 320px; gap: 32px;"
        >
          <div role="tabpanel" aria-label={t(`event_detail.tab_${activeTab}`)}>
            {activeTab === 'upcoming' && (
              <>
                <div
                  style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; padding-bottom: 24px; border-bottom: 1px solid var(--border); margin-bottom: 24px;"
                >
                  <div>
                    <p
                      class="section-eyebrow"
                      style="margin-bottom: 4px; font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--muted-foreground);"
                    >
                      {t('event_detail.date')}
                    </p>
                    <p style="font-size: 14px; margin: 0;">{fullDate}</p>
                    <p style="font-family: var(--font-mono); font-size: 12px; color: var(--muted-foreground); margin: 2px 0 0;">
                      {startTime} — {endTime}
                    </p>
                  </div>
                  <div>
                    <p
                      class="section-eyebrow"
                      style="margin-bottom: 4px; font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--muted-foreground);"
                    >
                      {event.venue ? t('event_detail.venue') : t('event_detail.location')}
                    </p>
                    <p style="font-size: 14px; margin: 0;">
                      {event.venue ?? event.location ?? t('home.location_tba')}
                    </p>
                    {event.address && (
                      <p style="font-size: 13px; color: var(--muted-foreground); margin: 2px 0 0;">{event.address}</p>
                    )}
                  </div>
                </div>

                {mapEmbedSrc && (
                  <section style="margin: 0 0 24px;">
                    <iframe
                      src={mapEmbedSrc}
                      title={t('event_detail.map_title')}
                      loading="lazy"
                      style="width: 100%; height: 280px; border: 1px solid var(--border); border-radius: 8px; display: block;"
                    />
                  </section>
                )}

                {externalMaps && (
                  <section style="margin: 0 0 32px; display: flex; flex-wrap: wrap; gap: 8px;">
                    <a
                      href={externalMaps.google}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="btn btn-ghost btn-sm"
                    >
                      {t('event_detail.open_google_maps')} ↗
                    </a>
                    <a
                      href={externalMaps.yandex}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="btn btn-ghost btn-sm"
                    >
                      {t('event_detail.open_yandex_maps')} ↗
                    </a>
                    {event.mapUrl && (
                      <a
                        href={event.mapUrl}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="btn btn-ghost btn-sm"
                      >
                        {t('event_detail.view_map')} ↗
                      </a>
                    )}
                  </section>
                )}

                <h2 style="font-family: var(--font-display); font-weight: 600; font-size: 20px; letter-spacing: -0.01em; margin: 0 0 12px;">
                  {t('event_detail.about')}
                </h2>
                <p style="font-size: 15px; line-height: 1.65; color: var(--muted-foreground); margin: 0 0 24px; white-space: pre-line;">
                  {event.description}
                </p>

                {agendaHtml && (
                  <section style="margin: 0 0 32px;">
                    <h2 style="font-family: var(--font-display); font-weight: 600; font-size: 20px; letter-spacing: -0.01em; margin: 0 0 12px;">
                      {t('event_detail.agenda')}
                    </h2>
                    <div style="font-size: 14px; line-height: 1.65; color: var(--muted-foreground);" set:html={agendaHtml} />
                  </section>
                )}

                {event.externalLinks && event.externalLinks.length > 0 && (
                  <section style="margin: 0 0 32px;">
                    <h2 style="font-family: var(--font-display); font-weight: 600; font-size: 20px; letter-spacing: -0.01em; margin: 0 0 12px;">
                      {t('event_detail.links')}
                    </h2>
                    <ul class="pill-row__list">
                      {event.externalLinks.map((link) => (
                        <li>
                          <a class="pill-row" href={link.url} target="_blank" rel="noopener noreferrer">
                            <span class="pill-row__badge badge mono">
                              {t(`event_detail.link_kind_${link.kind ?? 'other'}`)}
                            </span>
                            <span class="pill-row__label">{link.label}</span>
                            <span class="pill-row__arrow" aria-hidden="true">↗</span>
                          </a>
                        </li>
                      ))}
                    </ul>
                  </section>
                )}

                {speakers.length > 0 && (
                  <section style="margin: 0 0 32px;">
                    <div style="display: flex; align-items: baseline; justify-content: space-between; margin: 0 0 16px;">
                      <h2 style="font-family: var(--font-display); font-weight: 600; font-size: 20px; letter-spacing: -0.01em; margin: 0;">
                        {t('event_detail.speakers')}
                      </h2>
                      <span style="font-family: var(--font-mono); font-size: 11px; color: var(--muted-foreground);">
                        {t('event_detail.speakers_confirmed_of', { confirmed: confirmedSpeakers.length, total: speakers.length })}
                      </span>
                    </div>
                    <ul style="list-style: none; margin: 0; padding: 0; display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 12px;">
                      {speakers.map((s) => (
                        <li style="border: 1px solid var(--border); border-radius: 8px; padding: 14px;">
                          <p style="font-weight: 600; font-size: 14px; margin: 0 0 2px;">
                            {s.handle ? (
                              <a href={`/u/${s.handle}`} style="color: inherit; text-decoration: none;">
                                {s.displayName ?? `@${s.handle}`}
                              </a>
                            ) : (
                              s.displayName ?? '—'
                            )}
                          </p>
                          {s.jobTitle && (
                            <p style="font-size: 12px; color: var(--muted-foreground); margin: 0 0 8px;">{s.jobTitle}</p>
                          )}
                          {s.talkTitle && (
                            <p style="font-size: 13px; margin: 8px 0 0;"><em>{s.talkTitle}</em></p>
                          )}
                          {s.status === 'accepted' && (
                            <span class="badge mono" style="margin-top: 8px; display: inline-block; font-size: 9px;">PENDING</span>
                          )}
                        </li>
                      ))}
                    </ul>
                  </section>
                )}

                {materials.length > 0 && (
                  <section style="margin: 0 0 32px;">
                    <h2 style="font-family: var(--font-display); font-weight: 600; font-size: 20px; letter-spacing: -0.01em; margin: 0 0 12px;">
                      {t('event_detail.materials')}
                    </h2>
                    <ul class="pill-row__list">
                      {materials.map((m) => (
                        <li>
                          <a class="pill-row" href={m.url ?? m.fileUrl ?? '#'} target="_blank" rel="noopener noreferrer">
                            <span class="pill-row__badge badge mono">
                              {t(`event_detail.material_kind_${m.kind}`)}
                            </span>
                            <span class="pill-row__label">{m.title}</span>
                            <span class="pill-row__arrow" aria-hidden="true">↗</span>
                          </a>
                        </li>
                      ))}
                    </ul>
                  </section>
                )}
              </>
            )}

            {activeTab === 'live' && (
              livestreamEmbedSrc ? (
                <section style="margin: 0 0 32px;">
                  <div style="position: relative; padding-bottom: 56.25%; height: 0; overflow: hidden; border-radius: 8px; border: 1px solid var(--border);">
                    <iframe
                      src={livestreamEmbedSrc}
                      title={t('event_detail.livestream_title', { title: event.title })}
                      loading="lazy"
                      allow="accelerometer; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                      allowfullscreen
                      style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; border: 0;"
                    />
                  </div>
                </section>
              ) : livestreamUrl ? (
                <section style="margin: 0 0 32px; display: flex; flex-direction: column; align-items: flex-start; gap: 12px;">
                  <p style="font-size: 15px; color: var(--muted-foreground); margin: 0;">
                    {t('event_detail.livestream_join_body')}
                  </p>
                  <a href={livestreamUrl} target="_blank" rel="noopener noreferrer" class="btn btn-primary">
                    {t('event_detail.livestream_join_cta')} ↗
                  </a>
                </section>
              ) : (
                <div class="empty-state" style="margin: 24px 0;">
                  <div class="empty-icon" aria-hidden="true">📡</div>
                  <p class="empty-heading">{t('event_detail.tab_live_empty_title')}</p>
                  <p class="empty-desc">{t('event_detail.tab_live_empty_body')}</p>
                </div>
              )
            )}

            {activeTab === 'finished' && (
              hasFinishedContent ? (
                <>
                  {recapHtml && (
                    <section style="margin: 0 0 32px;">
                      <h2 style="font-family: var(--font-display); font-weight: 600; font-size: 20px; letter-spacing: -0.01em; margin: 0 0 12px;">
                        {t('event_detail.recap')}
                      </h2>
                      <div style="font-size: 15px; line-height: 1.65; color: var(--muted-foreground);" set:html={recapHtml} />
                    </section>
                  )}

                  {recordings.length > 0 && (
                    <section style="margin: 0 0 32px;">
                      <h2 style="font-family: var(--font-display); font-weight: 600; font-size: 20px; letter-spacing: -0.01em; margin: 0 0 12px;">
                        {t('event_detail.recordings')}
                      </h2>
                      <ul style="list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 16px;">
                        {recordings.map((r) => (
                          <li>
                            <p style="font-size: 13px; color: var(--muted-foreground); margin: 0 0 8px;">{r.title}</p>
                            <div style="position: relative; padding-bottom: 56.25%; height: 0; overflow: hidden; border-radius: 8px; border: 1px solid var(--border);">
                              <iframe
                                src={r.embedSrc}
                                title={r.title}
                                loading="lazy"
                                allow="accelerometer; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                                allowfullscreen
                                style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; border: 0;"
                              />
                            </div>
                          </li>
                        ))}
                      </ul>
                    </section>
                  )}

                  {photos.length > 0 && (
                    <section style="margin: 0 0 32px;">
                      <h2 style="font-family: var(--font-display); font-weight: 600; font-size: 20px; letter-spacing: -0.01em; margin: 0 0 12px;">
                        {t('event_detail.photos')}
                      </h2>
                      <ul style="list-style: none; margin: 0; padding: 0; display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 8px;">
                        {photos.map((p) => {
                          const src = p.fileUrl ?? p.url ?? '';
                          const alt = p.altText ?? p.caption ?? t('event_detail.photo_alt_fallback', { title: event.title });
                          return (
                            <li>
                              <a
                                href={src}
                                target="_blank"
                                rel="noopener noreferrer"
                                style="display: block; border: 1px solid var(--border); border-radius: 8px; overflow: hidden; aspect-ratio: 4 / 3; background: var(--muted);"
                              >
                                <img
                                  src={src}
                                  alt={alt}
                                  loading="lazy"
                                  style="width: 100%; height: 100%; object-fit: cover; display: block;"
                                />
                              </a>
                              {p.caption && (
                                <p style="font-size: 11px; color: var(--muted-foreground); margin: 6px 0 0;">{p.caption}</p>
                              )}
                            </li>
                          );
                        })}
                      </ul>
                    </section>
                  )}
                </>
              ) : (
                <div class="empty-state" style="margin: 24px 0;">
                  <div class="empty-icon" aria-hidden="true">📼</div>
                  <p class="empty-heading">{t('event_detail.tab_finished_empty_title')}</p>
                  <p class="empty-desc">{t('event_detail.tab_finished_empty_body')}</p>
                </div>
              )
            )}

            {activeTab === 'forum' && (
              <div class="empty-state" style="margin: 24px 0;">
                <div class="empty-icon" aria-hidden="true">💬</div>
                <p class="empty-heading">{t('event_detail.tab_forum_empty_title')}</p>
                <p class="empty-desc">{t('event_detail.tab_forum_empty_body')}</p>
              </div>
            )}
          </div>

          <div>
            <RegistrationSidebar event={event} client:load />
            <EventShareButtons
              eventId={event.id}
              eventTitle={event.title}
              eventUrl={`${Astro.url.origin}/events/${event.id}`}
              client:load
            />

            {sponsors.length > 0 && (
              <section style="margin-top: 24px; padding-top: 24px; border-top: 1px solid var(--border);">
                <p
                  class="section-eyebrow"
                  style="margin: 0 0 12px; font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--muted-foreground);"
                >
                  {t('event_detail.sponsors')}
                </p>
                <ul style="list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 12px;">
                  {sponsors.map((s) => {
                    const inner = (
                      <div style="display: flex; align-items: center; gap: 10px; padding: 10px; border: 1px solid var(--border); border-radius: 8px; background: var(--card);">
                        {s.sponsor.logoUrl ? (
                          <img
                            src={s.sponsor.logoUrl}
                            alt={s.sponsor.name}
                            loading="lazy"
                            style="width: 40px; height: 40px; object-fit: contain; border-radius: 4px; background: var(--background); flex-shrink: 0;"
                          />
                        ) : (
                          <div
                            aria-hidden="true"
                            style="width: 40px; height: 40px; border-radius: 4px; background: var(--muted); flex-shrink: 0;"
                          />
                        )}
                        <div style="display: flex; flex-direction: column; gap: 2px; min-width: 0; flex: 1;">
                          <p style="font-weight: 600; font-size: 13px; margin: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                            {s.sponsor.name}
                          </p>
                          <span
                            class="badge mono"
                            style="font-size: 9px; letter-spacing: 0.08em; padding: 1px 6px; align-self: flex-start;"
                          >
                            {t(`event_detail.sponsor_tier_${s.tier}`)}
                          </span>
                          {s.customMessage && (
                            <p style="font-size: 11px; color: var(--muted-foreground); margin: 2px 0 0;">{s.customMessage}</p>
                          )}
                        </div>
                      </div>
                    );
                    return s.sponsor.website ? (
                      <li>
                        <a
                          href={s.sponsor.website}
                          target="_blank"
                          rel="noopener noreferrer"
                          style="text-decoration: none; color: inherit; display: block;"
                        >
                          {inner}
                        </a>
                      </li>
                    ) : (
                      <li>{inner}</li>
                    );
                  })}
                </ul>
              </section>
            )}
          </div>
        </div>
      </div>
    )}
  </main>
</Layout>
