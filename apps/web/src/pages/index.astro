---
import HomeHero from '../components/HomeHero.astro';
import { LeadCaptureForm } from '../components/LeadCaptureForm';
import UpcomingEventsGrid from '../components/UpcomingEventsGrid.astro';
import Layout from '../layouts/Layout.astro';
import {
  countryFromHost,
  fetchHomepageStats,
  fetchPartners,
  fetchRecentRecordings,
  fetchUpcomingEvents,
} from '../lib/cms';
import { geoTargetSubdomain, hostnameFromHeaders, isApexHost } from '../lib/geo';
import { getLocale, makeT } from '../lib/i18n';

// Country homepage per design screen s1-1.
//
// Apex (aiqadam.org) redirects via Cloudflare's CF-IPCountry to a country
// subdomain — see lib/geo.ts. On a country sub (uz/kz/tj.aiqadam.org) we
// render the homepage: hero anchored on the next upcoming event, 3-event
// upcoming grid, partners row, join-the-community CTA.
//
// Event data comes from the API server-side — fetchUpcomingEvents forwards
// the Host header so tenant resolution returns the right country. Empty
// array on fetch failure → empty state shows; never blocks the page.
export const prerender = false;

const url = new URL(Astro.request.url);

if (isApexHost(hostnameFromHeaders(Astro.request.headers))) {
  return Astro.redirect(
    `https://${geoTargetSubdomain(Astro.request.headers)}.aiqadam.org${url.pathname}${url.search}`,
    302,
  );
}

const locale = getLocale(Astro);
const t = makeT(locale);
const country = countryFromHost(Astro.request.headers.get('host'));
const countryName = t(`country.${country}`);

// F-WebU13 — homepage uplift adds three SSR-fetched surfaces beside
// the existing hero / grid / partners / lead capture / CTA layout:
//   - mission band (top): identity + country context. Strings only.
//   - trust strip (between grid and partners): three stat cards
//     computed via Directus aggregate queries — past events + partners
//     + countries served. Anonymous + cheap.
//   - recent recordings (between partners and lead capture): up to 3
//     most recent kind=recording event_materials for this country,
//     deep-joined to event title. Click-through to /events/<id>?tab=finished.
const [events, partners, stats, recordings] = await Promise.all([
  fetchUpcomingEvents(Astro.request),
  fetchPartners(Astro.request),
  fetchHomepageStats(Astro.request),
  fetchRecentRecordings(Astro.request, 3),
]);
const hero = events[0] ?? null;
const grid = events.slice(1, 4);
const countriesServed = 3;
---

<Layout title="AI Qadam">
  <main style="max-width: 1180px; margin: 0 auto;">
    <section style="padding: 28px 48px 0;">
      <p
        class="section-eyebrow"
        style="margin: 0 0 6px; font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--muted-foreground);"
      >
        {t('home.mission_eyebrow', { country: countryName })}
      </p>
      <p style="font-size: 16px; line-height: 1.55; color: var(--foreground); margin: 0; max-width: 760px;">
        {t('home.mission_body')}
      </p>
    </section>

    <HomeHero event={hero} locale={locale} />
    <UpcomingEventsGrid events={grid} locale={locale} />

    <section style="padding: 32px 48px; border-top: 1px solid var(--border);">
      <ul style="list-style: none; margin: 0; padding: 0; display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px;">
        <li
          style="border: 1px solid var(--border); border-radius: 12px; padding: 20px; background: var(--card);"
        >
          <p style="font-family: var(--font-mono); font-size: 32px; font-weight: 600; margin: 0; letter-spacing: -0.02em;">
            {stats.pastEventsCount}
          </p>
          <p style="font-size: 13px; color: var(--muted-foreground); margin: 4px 0 0;">
            {t('home.stat_events_run')}
          </p>
        </li>
        <li
          style="border: 1px solid var(--border); border-radius: 12px; padding: 20px; background: var(--card);"
        >
          <p style="font-family: var(--font-mono); font-size: 32px; font-weight: 600; margin: 0; letter-spacing: -0.02em;">
            {stats.partnersCount}
          </p>
          <p style="font-size: 13px; color: var(--muted-foreground); margin: 4px 0 0;">
            {t('home.stat_partners')}
          </p>
        </li>
        <li
          style="border: 1px solid var(--border); border-radius: 12px; padding: 20px; background: var(--card);"
        >
          <p style="font-family: var(--font-mono); font-size: 32px; font-weight: 600; margin: 0; letter-spacing: -0.02em;">
            {countriesServed}
          </p>
          <p style="font-size: 13px; color: var(--muted-foreground); margin: 4px 0 0;">
            {t('home.stat_countries')}
          </p>
        </li>
      </ul>
    </section>

    {partners.length > 0 && (
      <section style="padding: 48px; border-top: 1px solid var(--border);">
        <p
          class="section-eyebrow"
          style="margin-bottom: 16px; font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--muted-foreground);"
        >
          {t('home.partners')}
        </p>
        <div style="display: grid; grid-template-columns: repeat(6, 1fr); gap: 10px;">
          {partners.map((p) => (
            p.url ? (
              <a
                href={p.url}
                target="_blank"
                rel="noopener"
                style="height: 56px; border: 1px solid var(--border); border-radius: 8px; display: flex; align-items: center; justify-content: center; font-family: var(--font-mono); font-size: 11px; color: var(--muted-foreground); letter-spacing: 0.06em; text-decoration: none;"
              >
                {p.name}
              </a>
            ) : (
              <div
                style="height: 56px; border: 1px solid var(--border); border-radius: 8px; display: flex; align-items: center; justify-content: center; font-family: var(--font-mono); font-size: 11px; color: var(--muted-foreground); letter-spacing: 0.06em;"
              >
                {p.name}
              </div>
            )
          ))}
        </div>
      </section>
    )}

    {recordings.length > 0 && (
      <section style="padding: 48px; border-top: 1px solid var(--border);">
        <p
          class="section-eyebrow"
          style="margin-bottom: 16px; font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--muted-foreground);"
        >
          {t('home.recent_recordings')}
        </p>
        <ul style="list-style: none; margin: 0; padding: 0; display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 12px;">
          {recordings.map((r) => (
            <li>
              <a
                href={`/events/${r.eventId}?tab=finished`}
                style="display: flex; flex-direction: column; gap: 6px; padding: 14px; border: 1px solid var(--border); border-radius: 8px; background: var(--card); text-decoration: none; color: inherit; transition: border-color 150ms var(--ease-out);"
              >
                <span class="badge mono" style="font-size: 9px; letter-spacing: 0.08em; align-self: flex-start;">
                  {t('event_detail.material_kind_recording')}
                </span>
                <p style="font-size: 14px; font-weight: 600; margin: 4px 0 0; line-height: 1.35;">{r.title}</p>
                <p style="font-size: 12px; color: var(--muted-foreground); margin: 0;">
                  {r.eventTitle}
                </p>
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}

    <section style="padding: 48px; border-top: 1px solid var(--border);">
      <div style="max-width: 540px; margin: 0 auto;">
        <LeadCaptureForm client:load />
      </div>
    </section>

    <section style="padding: 48px; border-top: 1px solid var(--border);">
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
        <article
          style="padding: 24px; border: 1px solid color-mix(in oklch, #229ED9 50%, var(--border)); border-radius: 12px; background: var(--card); display: flex; flex-direction: column; gap: 14px;"
        >
          <div>
            <h4 style="font-family: var(--font-display); font-weight: 600; font-size: 17px; margin: 0 0 4px;">
              {t('home.tg_title')}
            </h4>
            <p style="font-size: 13px; color: var(--muted-foreground); margin: 0;">
              {t('home.tg_desc')}
            </p>
          </div>
          <a
            class="btn btn-outline"
            href="https://t.me/aiqadam"
            target="_blank"
            rel="noopener"
            style="align-self: flex-start; text-decoration: none;"
          >
            {t('home.tg_cta')} →
          </a>
        </article>
        <article
          style="padding: 24px; border: 1px solid var(--border); border-radius: 12px; background: var(--card); display: flex; flex-direction: column; gap: 14px;"
        >
          <div>
            <h4 style="font-family: var(--font-display); font-weight: 600; font-size: 17px; margin: 0 0 4px;">
              {t('home.partner_title')}
            </h4>
            <p style="font-size: 13px; color: var(--muted-foreground); margin: 0;">
              {t('home.partner_desc')}
            </p>
          </div>
          <a
            class="btn btn-outline"
            href="mailto:partners@aiqadam.org"
            style="align-self: flex-start; text-decoration: none;"
          >
            {t('home.partner_cta')} →
          </a>
        </article>
      </div>
    </section>
  </main>
</Layout>
