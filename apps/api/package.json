    "@types/supertest": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.10",
    "drizzle-kit": "^0.31.10",
    "supertest": "^7.0.0",
    "testcontainers": "^12.0.4",
    "ts-node": "^10.9.2",
    "tsx": "^4.23.1",
    "typescript": "^5.7.2",
    "vitest": "^4.1.10"
