    "@nestjs/schedule": "^6.1.3",
    "@nestjs/throttler": "^6",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "ioredis": "^5",
    "jose": "^6.2.3",
    "nodemailer": "^9.0.1",
    "openid-client": "^5.7.1",
    "pdfkit": "^0.19.1",
    "postgres": "^3.4.5",
