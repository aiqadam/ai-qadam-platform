# apps/api/.env.example
# Copy to apps/api/.env and edit. Production credentials live in Coolify.

NODE_ENV=development
PORT=3000

# Local Postgres from infrastructure/docker-compose.yml. The 'platform'
# database is owned by this service. If you set POSTGRES_HOST_PORT in
# infrastructure/.env (e.g. because you have a local Postgres on 5432),
# match the port here.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/platform

# Local Redis from infrastructure/docker-compose.yml.
REDIS_URL=redis://localhost:6379

# Symmetric key for signing access tokens (ADR-0016). Generate locally — never
# reuse across machines or environments. >=32 chars enforced by env.ts.
#   openssl rand -base64 48 | tr -d '\n'
JWT_SIGNING_SECRET=

# Authentik OIDC application — see docs/runbooks/authentik-local-bootstrap.md
# for how to obtain these values. The slug 'aiqadam-platform-local' matches
# what the runbook tells you to enter when creating the Application + Provider.
OIDC_ISSUER_URL=http://localhost:9000/application/o/aiqadam-platform-local/
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
# Must EXACTLY match a Redirect URI registered on the Authentik application.
# We use the web's same-origin proxy (apps/web/astro.config.mjs) so the
# browser only ever talks to :4321 and the __Host- cookie stays same-origin.
OIDC_REDIRECT_URI=http://localhost:4321/api/v1/auth/callback
# Where the API sends the browser after a successful login (the web app root).
WEB_BASE_URL=http://localhost:4321

# Email (Resend, ADR-0009). Set SEND_EMAILS=true to actually transmit; in
# dev leave it false unless you're testing email content. RESEND_API_KEY
# is fetched from your Resend dashboard. EMAIL_FROM must be a verified
# sender on that account.
SEND_EMAILS=false
RESEND_API_KEY=
EMAIL_FROM=AI Qadam <admin@aiqadam.org>

# Shared secret for /v1/internal/* endpoints (Directus → API). Must be 32+
# chars. Generate locally with `openssl rand -hex 32`. The Directus side
# stores the same value as an env var listed in FLOWS_ENV_ALLOW_LIST, so
# flow `request` ops can read it as {{ $env.INTERNAL_API_TOKEN }}.
INTERNAL_API_TOKEN=

# Outbound calls to Directus (Sprint 4.5: API proxies member registration /
# check-in / leaderboard endpoints). The token is a static admin token
# from a directus_users.token row provisioned in Sprint 1. URL defaults
# to https://cms.aiqadam.org in production.
DIRECTUS_URL=https://cms.aiqadam.org
DIRECTUS_TOKEN=

# Shared bearer secret for /v1/telegram/* (ADR-0034). Optional — leave
# blank to run with telegram features dormant. When set, must be 32+
# chars and identical to AIQADAM_SERVICE_TOKEN on the bot side. The
# operator wires this via the workspace cabinet (/workspace/integrations/
# telegram, planned) in prod; locally generate with:
#   openssl rand -hex 32
TELEGRAM_BOT_SERVICE_TOKEN=
