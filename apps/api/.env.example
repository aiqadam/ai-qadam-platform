# apps/api/.env.example
# Copy to apps/api/.env and edit. Production credentials live in Coolify.

NODE_ENV=development
PORT=3000

# Local Postgres from infrastructure/docker-compose.yml. The 'platform'
# database is owned by this service. If you set POSTGRES_HOST_PORT in
# infrastructure/.env (e.g. because you have a local Postgres on 5432),
# match the port here.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/platform

# Local Redis from infrastructure/docker-compose.yml.
REDIS_URL=redis://localhost:6379
