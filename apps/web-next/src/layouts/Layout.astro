---
import '../styles/globals.css';
import AppFooter from '../blocks/common/AppFooter.astro';
import AppNav from '../blocks/common/AppNav.astro';

interface Props {
  title?: string;
  description?: string;
}

// apps/web-next/ Layout — ADR-0038 greenfield build.
//
// Ported from apps/web/src/layouts/Layout.astro with three deltas:
//   1) Title defaults to "AI Qadam (next)" so engineers always know
//      they're on the build-aside, not the production site.
//   2) <meta name="robots" content="noindex,nofollow"> — next.aiqadam.org
//      is engineer-only behind Authentik forward-auth; even if a crawler
//      hit a leaked URL it must NOT index v2 until cutover.
//   3) No OG / canonical / analytics tags. Build-aside has no
//      audience, and we don't want Plausible polluting v1 stats with
//      engineer test traffic.
//
// PR-0d wires the L1 runtime here: <RuntimeProvider> bundles the
// TanStack QueryClientProvider + the AuthProvider so every React
// island gets useQuery() and useAuth() from a single client:load
// boundary. The SSR auth blob is also still injected as a window
// global for any consumer that prefers the v1-style direct read.
const { title = 'AI Qadam (next)', description = 'AI Qadam web v2 — build-aside per ADR-0038.' } =
  Astro.props;

const ssrAuth = Astro.locals.auth;
const ssrAuthInject = ssrAuth !== undefined;
const ssrAuthJson = ssrAuthInject ? JSON.stringify(ssrAuth).replace(/</g, '\\u003c') : null;
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="noindex,nofollow" />
    <title>{title}</title>
    <link rel="icon" type="image/png" href="/brand/aiqadam-mark.png" />
    <slot name="head" />
    {ssrAuthInject && <script is:inline set:html={`window.__AIQADAM_AUTH__ = ${ssrAuthJson};`} />}
  </head>
  <body class="min-h-screen antialiased">
    <!--
      No page-level RuntimeProvider: Astro hydrates each `client:load`
      island as its own React root, so a Layout-level provider reaches
      none of them. Every interactive island self-wraps in <IslandRoot>
      (see lib/island-root.tsx). The window.__AIQADAM_AUTH__ blob above
      is what each island's RuntimeProvider reads for SSR auth state.
    -->
    <AppNav />
    <slot />
    <AppFooter />
  </body>
</html>
