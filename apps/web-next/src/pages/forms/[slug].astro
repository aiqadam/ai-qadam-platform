---
// @generated-from gen:page
// slug: forms/[slug]
// FR-MIG-019 — public form renderer.
//
// SSR-fetches form schema by slug; renders fields using <FormRenderer>.
// Respects allow_anonymous flag: if false, shows AuthGate.
// Handles expired/closed forms gracefully (404-style message).
//
// Wiring: docs/04-development/architecture/wiring-map.md → forms (public).
export const prerender = false;

import { AuthGate } from '@/blocks/common';
import { FormRenderer } from '@/blocks/customer/FormRenderer';
import { fetchPublicForm, type PublicForm } from '@/lib/api-ssr';
import Layout from '@/layouts/Layout.astro';

const { slug } = Astro.params as { slug: string };

const form: PublicForm | null = await fetchPublicForm(Astro.request, slug);
---

<Layout
  title={form ? `${form.title} · AI Qadam` : 'Form not found · AI Qadam'}
  description={form?.description ?? 'Submit your response.'}
>
  {form === null ? (
    <main class="mx-auto max-w-2xl px-6 py-24 text-center">
      <h1 class="mb-4 font-display text-3xl font-semibold">Form not found</h1>
      <p class="text-muted-foreground">
        This form doesn't exist or is no longer accepting responses.
      </p>
    </main>
  ) : form.status === 'archived' || form.status === 'draft' ? (
    <main class="mx-auto max-w-2xl px-6 py-24 text-center">
      <h1 class="mb-4 font-display text-3xl font-semibold">Form closed</h1>
      <p class="text-muted-foreground">
        This form is no longer accepting responses.
      </p>
    </main>
  ) : !form.allow_anonymous ? (
    <AuthGate signInLabel="Sign in to submit this form">
      <main class="mx-auto max-w-2xl px-6 py-24">
        <FormRenderer client:load form={form} />
      </main>
    </AuthGate>
  ) : (
    <main class="mx-auto max-w-2xl px-6 py-24">
      <FormRenderer client:load form={form} />
    </main>
  )}
</Layout>
