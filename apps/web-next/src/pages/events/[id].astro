---
// @generated-from gen:page
// slug: events/[id]
// generated: 2026-05-26
//
// Phase 1.3 + 1.4 — customer-facing event detail per ADR-0038.
//
// Composition only (L4): fetch event detail from apps/api + speakers
// / materials / sponsors from Directus, hand the typed payloads to
// the L3 blocks. Sidebar (RegistrationCTA + ShareButtons) renders
// via the EventDetail block's `sidebar` slot.
//
// Wiring: docs/architecture/wiring-map.md → events + event_speakers
// + event_materials + event_sponsors + registrations.
//
// SSR — needs the request Host header to forward to /v1/events (the
// API's per-country tenant filter).
export const prerender = false;

import {
  EventDetail,
  MaterialsList,
  RegistrationCTA,
  ShareButtons,
  SpeakerGrid,
  SponsorWall,
} from '../../blocks/customer';
import { PageHead } from '../../blocks/common';
import Layout from '../../layouts/Layout.astro';
import { fetchEvent } from '../../lib/api-ssr';
import { fetchEventMaterials, fetchEventSpeakers, fetchEventSponsors } from '../../lib/cms';

const { id } = Astro.params as { id: string };
const event = await fetchEvent(Astro.request, id);

if (!event) {
  return Astro.redirect('/events', 302);
}

const [speakers, materials, sponsors] = await Promise.all([
  fetchEventSpeakers(event.id),
  fetchEventMaterials(event.id),
  fetchEventSponsors(event.id),
]);

const canonicalUrl = `${Astro.url.protocol}//${Astro.url.host}/events/${event.id}`;
---

<Layout
  title={`${event.title} · AI Qadam (next)`}
  description={event.shortDescription ?? event.description.slice(0, 200)}
>
  <PageHead
    slot="head"
    title={`${event.title} · AI Qadam (next)`}
    description={event.shortDescription ?? event.description.slice(0, 200)}
  />
  <main>
    <EventDetail event={event}>
      <RegistrationCTA
        slot="sidebar"
        eventId={event.id}
        capacity={event.capacity}
        registeredCount={event.registeredCount}
        client:load
      />
      <ShareButtons
        slot="sidebar"
        eventId={event.id}
        eventTitle={event.title}
        eventUrl={canonicalUrl}
      />
      <SpeakerGrid speakers={speakers} />
      <MaterialsList materials={materials} />
      <SponsorWall sponsors={sponsors} />
    </EventDetail>
  </main>
</Layout>
