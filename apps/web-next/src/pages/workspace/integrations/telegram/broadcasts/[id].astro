---
// @generated-from gen:page
// @generated-from pattern:workspace/integrations/telegram/segments
// slug: workspace/integrations/telegram/broadcasts/[id]
// FR-MIG-015 — Telegram broadcast edit/view page with ActionBar.
export const prerender = false;

import { AuthGate, PageHead } from '../../../../../blocks/common';
import { Breadcrumbs, PageShell, TgBroadcastComposer } from '../../../../../blocks/workspace';
import Layout from '../../../../../layouts/Layout.astro';

const { id } = Astro.params;
if (!id) {
  return Astro.redirect('/workspace/integrations/telegram/broadcasts');
}
---

<Layout
  title={`Broadcast ${id} · Telegram · AI Qadam workspace`}
  description="Edit or view a Telegram broadcast campaign."
>
  <PageHead
    slot="head"
    title={`Broadcast ${id?.slice(0, 8)}… · Telegram · AI Qadam workspace`}
    description="View or edit this broadcast campaign."
  />
  <AuthGate role="aiqadam-operators" signInLabel="Operators only — sign in">
    <PageShell
      title="Broadcast"
      description="Edit this broadcast campaign."
      width="wide"
    >
      <Breadcrumbs
        slot="breadcrumbs"
        items={[
          { label: 'Workspace', href: '/workspace' },
          { label: 'Integrations', href: '/workspace/integrations' },
          { label: 'Telegram', href: '/workspace/integrations/telegram' },
          { label: 'Broadcasts', href: '/workspace/integrations/telegram/broadcasts' },
          { label: id ? id.slice(0, 8) + '…' : 'Edit' },
        ]}
      />
      <TgBroadcastComposer client:load broadcastId={id} />
    </PageShell>
  </AuthGate>
</Layout>
