---
// L3 workspace block — <PageShell>.
//
// Operator-cabinet page wrapper. Every `/workspace/...` page composes
// this once at the top; cabinet-specific content goes in the body
// slot. Three named slots for everything else:
//
//   slot="breadcrumbs"  → typically a <Breadcrumbs items={...} />
//   slot="actions"      → top-right action area (buttons / menus)
//   slot (default)      → page body (DataTable, Form, KpiTile grid, …)
//
// `title` and optional `description` render in the page header. The
// shell deliberately stays presentation-only: page-level role gating
// stays a page concern via <AuthGate>, and data fetching stays in the
// page frontmatter (not the shell) per ADR-0038 §Locks #1.

interface Props {
  title: string;
  description?: string | undefined;
  // Max-width preset for the body. Cabinets that show wide tables
  // (Members, Audit, Telegram) opt into 'wide'; default 'standard'.
  width?: 'standard' | 'wide' | 'narrow';
}

const { title, description, width = 'standard' } = Astro.props;

const WIDTH_CLASS: Record<NonNullable<Props['width']>, string> = {
  narrow: 'max-w-3xl',
  standard: 'max-w-5xl',
  wide: 'max-w-7xl',
};
---

<main class={`mx-auto ${WIDTH_CLASS[width]} px-6 py-10`}>
  <slot name="breadcrumbs" />
  <header class="flex items-start justify-between gap-4 mt-3 mb-8 pb-6 border-b border-border">
    <div class="min-w-0">
      <h1 class="font-display text-3xl font-semibold tracking-tight text-foreground m-0">
        {title}
      </h1>
      {
        description && (
          <p class="text-sm text-muted-foreground mt-2 m-0 leading-relaxed">{description}</p>
        )
      }
    </div>
    <div class="flex items-center gap-2 shrink-0">
      <slot name="actions" />
    </div>
  </header>

  <slot />
</main>
