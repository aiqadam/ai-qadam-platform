---
// L3 block — <EmptyState>.
//
// Reusable "no data yet" surface. Used by every list/grid block when
// its data array is empty. One canonical shape replaces ~15 ad-hoc
// "no items found" widgets that live across v1 islands today.
//
// Props are intentionally minimal — heading + optional description.
// CTAs are intentionally NOT a prop: callers compose `<EmptyState>`
// with an adjacent `<a class="btn">` outside the block if a CTA is
// needed. Keeps the block dumb + composable.

interface Props {
  heading: string;
  description?: string | undefined;
  icon?: string | undefined; // emoji or text glyph; kept minimal until we add an icon kit
}

const { heading, description, icon } = Astro.props;
---

<div
  class="border border-dashed border-border rounded-xl px-6 py-16 text-center bg-card"
  role="status"
>
  {icon && <div class="text-4xl mb-3 opacity-60" aria-hidden="true">{icon}</div>}
  <h3 class="font-display text-lg font-semibold text-foreground mb-2">{heading}</h3>
  {description && <p class="text-sm text-muted-foreground max-w-md mx-auto">{description}</p>}
</div>
