---
// L3 block — <MaterialsList>.
//
// Public materials attached to an event — slides, handouts, code
// links, recordings, etc. Each row is a pill linking to either the
// Directus-hosted file or the external URL.
//
// Data-in/element-out: receives EventMaterial[] from the page.
//
// Wiring: docs/04-development/architecture/wiring-map.md → event_materials.

import type { EventMaterial } from '../../lib/types';

interface Props {
  materials: EventMaterial[];
  heading?: string | undefined;
}

const { materials, heading = 'Materials' } = Astro.props;

const KIND_LABEL: Record<EventMaterial['kind'], string> = {
  slides: 'SLIDES',
  handout: 'HANDOUT',
  cheatsheet: 'CHEATSHEET',
  recording: 'RECORDING',
  code: 'CODE',
  other: 'LINK',
};
---

{
  materials.length > 0 && (
    <section class="mb-10">
      <h2 class="font-display text-xl font-semibold text-foreground mb-4">{heading}</h2>
      <ul class="space-y-2 list-none p-0 m-0">
        {materials.map((m) => (
          <li>
            <a
              href={m.url ?? m.fileUrl ?? '#'}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-3 px-3 py-2.5 rounded-lg border border-border bg-card no-underline text-inherit hover:border-primary/40 transition-colors"
            >
              <span class="font-mono text-[10px] px-1.5 py-0.5 rounded bg-secondary text-secondary-foreground tracking-wider shrink-0">
                {KIND_LABEL[m.kind]}
              </span>
              <span class="text-sm flex-1 truncate">{m.title}</span>
              <span class="text-xs text-muted-foreground shrink-0" aria-hidden="true">↗</span>
            </a>
          </li>
        ))}
      </ul>
    </section>
  )
}
