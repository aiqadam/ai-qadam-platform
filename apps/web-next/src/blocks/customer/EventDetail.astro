---
// L3 block — <EventDetail>.
//
// Single-event main surface. Renders the hero strip (format chip,
// date/venue, title), description, agenda (markdown-lite), and an
// optional external-links pill row.
//
// Data-in/element-out: receives a fully-typed ApiEvent.
//
// Sidebar concerns (registration CTA, share buttons) ship in PR 1.4
// as separate blocks composed alongside this one in the page. Map
// embed + tabs (live / finished / forum) deferred per Phase 1.3
// scope-trim — those land as additive blocks on the same page.
//
// Wiring: docs/architecture/wiring-map.md → events.

import type { ApiEvent } from '../../lib/types';

interface Props {
  event: ApiEvent;
}

const { event } = Astro.props;

const FORMAT_LABEL: Record<ApiEvent['format'], string> = {
  meetup: 'MEETUP',
  workshop: 'WORKSHOP',
  hackathon: 'HACKATHON',
  conference: 'CONFERENCE',
  online: 'ONLINE',
};

const fullDate = new Date(event.startsAt).toLocaleDateString('en-US', {
  weekday: 'long',
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
const startTime = new Date(event.startsAt).toLocaleTimeString('en-US', {
  hour: '2-digit',
  minute: '2-digit',
  hour12: false,
});
const endTime = new Date(event.endsAt).toLocaleTimeString('en-US', {
  hour: '2-digit',
  minute: '2-digit',
  hour12: false,
});

const LINK_KIND_LABEL: Record<string, string> = {
  website: 'WEBSITE',
  registration: 'REGISTER',
  sponsor: 'SPONSOR',
  livestream: 'LIVESTREAM',
  recording: 'RECORDING',
  other: 'LINK',
};

// Markdown-ish agenda — split blank-line blocks; lines starting
// with `- ` become bullets, otherwise paragraphs. Full markdown
// is overkill for what operators put here.
function renderAgenda(md: string): string {
  const blocks = md.split(/\n\s*\n/);
  const escapeHtml = (s: string) =>
    s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  return blocks
    .map((block) => {
      const lines = block.split('\n').map((l) => l.trim()).filter(Boolean);
      if (lines.length === 0) return '';
      if (lines.every((l) => l.startsWith('- '))) {
        return `<ul class="list-disc pl-5 mb-3 text-muted-foreground">${lines
          .map((l) => `<li>${escapeHtml(l.slice(2))}</li>`)
          .join('')}</ul>`;
      }
      return `<p class="mb-3 text-muted-foreground">${lines.map(escapeHtml).join('<br/>')}</p>`;
    })
    .filter(Boolean)
    .join('');
}

const agendaHtml = event.agendaMd ? renderAgenda(event.agendaMd) : null;
---

<!--
  Hero strip. v2 first cut renders a solid-color band with format
  chip + title. Hero IMAGE backgrounds (event.heroImageUrl) need a
  runtime CSS variable approach (Astro `define:vars` + class-bound
  style) which I'm deferring to a follow-up to keep this PR within
  the size cap. The hero image was a nice-to-have in v1; absent
  surface renders cleanly.
-->
<section class="border-b border-border bg-card">
  <div class="mx-auto max-w-5xl px-6 py-12">
    <div class="flex items-center gap-2 mb-4">
      <span class="font-mono text-[10px] px-2 py-0.5 rounded bg-secondary text-secondary-foreground tracking-wider">
        {FORMAT_LABEL[event.format]}
      </span>
    </div>
    <h1 class="font-display text-3xl sm:text-4xl font-semibold tracking-tight text-foreground max-w-3xl">
      {event.title}
    </h1>
  </div>
</section>

<section class="mx-auto max-w-5xl px-6 py-8">
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 pb-6 mb-6 border-b border-border">
    <div>
      <p class="font-mono text-[10px] uppercase tracking-wider text-muted-foreground mb-1">
        Date
      </p>
      <p class="text-sm text-foreground">{fullDate}</p>
      <p class="font-mono text-xs text-muted-foreground mt-1">
        {startTime} — {endTime}
      </p>
    </div>
    <div>
      <p class="font-mono text-[10px] uppercase tracking-wider text-muted-foreground mb-1">
        {event.venue ? 'Venue' : 'Location'}
      </p>
      <p class="text-sm text-foreground">
        {event.venue ?? event.location ?? 'Location TBA'}
      </p>
      {event.address && (
        <p class="text-xs text-muted-foreground mt-1">{event.address}</p>
      )}
    </div>
  </div>

  <h2 class="font-display text-xl font-semibold text-foreground mb-3">About</h2>
  <p class="text-base text-muted-foreground leading-relaxed mb-8 whitespace-pre-line">
    {event.description}
  </p>

  {agendaHtml && (
    <section class="mb-10">
      <h2 class="font-display text-xl font-semibold text-foreground mb-3">Agenda</h2>
      <div class="text-sm leading-relaxed" set:html={agendaHtml} />
    </section>
  )}

  {event.externalLinks && event.externalLinks.length > 0 && (
    <section class="mb-10">
      <h2 class="font-display text-xl font-semibold text-foreground mb-3">Links</h2>
      <ul class="space-y-2 list-none p-0 m-0">
        {event.externalLinks.map((link) => (
          <li>
            <a
              href={link.url}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-3 px-3 py-2.5 rounded-lg border border-border bg-card no-underline text-inherit hover:border-primary/40 transition-colors"
            >
              <span class="font-mono text-[10px] px-1.5 py-0.5 rounded bg-secondary text-secondary-foreground tracking-wider shrink-0">
                {LINK_KIND_LABEL[link.kind ?? 'other'] ?? 'LINK'}
              </span>
              <span class="text-sm flex-1 truncate">{link.label}</span>
              <span class="text-xs text-muted-foreground shrink-0" aria-hidden="true">↗</span>
            </a>
          </li>
        ))}
      </ul>
    </section>
  )}

  <slot />
</section>
