{
  "name": "@aiqadam/e2e",
  "version": "0.0.0",
  "private": true,
  "description": "Playwright smoke tests + browser-agent verification (Sprint 0.10).",
  "type": "module",
  "scripts": {
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "report": "playwright show-report",
    "install:browsers": "playwright install --with-deps chromium",
    "e2e:parity": "playwright test --config playwright.parity.config.ts",
    "e2e:parity:v1": "playwright test --config playwright.parity.config.ts --project v1-chromium",
    "e2e:parity:v2": "playwright test --config playwright.parity.config.ts --project v2-chromium",
    "lhci:run": "npx @lhci/cli@0.14 autorun --config lighthouserc.js"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0"
  }
}
