{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "organizeImports": {
    "enabled": false
  },
  "formatter": {
    "enabled": false
  },
  "javascript": {
    "parser": {
      "unsafeParameterDecoratorsEnabled": true
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "correctness": {
        "noUnusedVariables": "error",
        "noUnusedImports": "error",
        "noUnusedFunctionParameters": "error",
        "noConstructorReturn": "off",
        "noInvalidUseBeforeDeclaration": "off",
        "noEmptyPattern": "off",
        "noConstantCondition": "off",
        "noSwitchDeclarations": "off",
        "noInnerDeclarations": "off",
        "noSelfAssign": "off"
      },
      "style": {
        "useConst": "error",
        "useTemplate": "error",
        "noNonNullAssertion": "error",
        "noParameterAssign": "off",
        "noCommaOperator": "off",
        "noVar": "off",
        "noUselessElse": "off",
        "useSingleVarDeclarator": "off",
        "useWhile": "off",
        "useImportType": "off",
        "useNumberNamespace": "off",
        "useExponentiationOperator": "off"
      },
      "suspicious": {
        "noExplicitAny": "error",
        "noConsoleLog": "off",
        "noAssignInExpressions": "off",
        "noDoubleEquals": "off",
        "noFallthroughSwitchClause": "off",
        "noControlCharactersInRegex": "off",
        "noPrototypeBuiltins": "off",
        "noRedeclare": "off",
        "noMisleadingCharacterClass": "off",
        "noConfusingLabels": "off",
        "useValidTypeof": "off",
        "useIsArray": "off",
        "noGlobalIsNan": "off",
        "noLabelVar": "off",
        "noSelfCompare": "off",
        "noThenProperty": "off"
      },
      "complexity": {
        "noExcessiveCognitiveComplexity": "off",
        "noForEach": "off",
        "noMultipleSpacesInRegularExpressionLiterals": "off",
        "noUselessLoneBlockStatements": "off",
        "useOptionalChain": "off",
        "noUselessSwitchCase": "off",
        "noUselessLabel": "off",
        "noThisInStatic": "off",
        "useFlatMap": "off"
      },
      "performance": {
        "noDelete": "off"
      },
      "a11y": {
        "useGenericFontNames": "off"
      }
    }
  },
  "overrides": [
    {
      "include": ["**/*.spec.ts", "**/*.test.ts", "**/*.spec.tsx", "**/*.test.tsx"],
      "linter": {
        "rules": {
          "style": {
            "noNonNullAssertion": "off"
          },
          "suspicious": {
            "noExplicitAny": "off"
          }
        }
      }
    },
    {
      "include": ["apps/web-next/src/blocks/**", "apps/web-next/src/pages/**"],
      "linter": {
        "rules": {
          "nursery": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "paths": {
                  "../lib/api-client": "ADR-0038 §Locks #1: blocks/pages may not import apiClient directly. Use an L1 query hook (useMyProfile, useEvent, ...).",
                  "../../lib/api-client": "ADR-0038 §Locks #1: blocks/pages may not import apiClient directly. Use an L1 query hook.",
                  "../../../lib/api-client": "ADR-0038 §Locks #1: blocks/pages may not import apiClient directly. Use an L1 query hook."
                }
              }
            }
          }
        }
      }
    },
    {
      "include": ["apps/web-next/src/blocks/**"],
      "linter": {
        "rules": {
          "nursery": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "paths": {
                  "../lib/api-queries": "ADR-0038 §Locks #1: blocks must receive data via props. Only pages may import L1 query hooks.",
                  "../../lib/api-queries": "ADR-0038 §Locks #1: blocks must receive data via props. Only pages may import L1 query hooks.",
                  "../../../lib/api-queries": "ADR-0038 §Locks #1: blocks must receive data via props. Only pages may import L1 query hooks."
                }
              }
            }
          }
        }
      }
    }
  ]
}
