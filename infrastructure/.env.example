# infrastructure/.env.example
#
# Copy this file to infrastructure/.env, then `docker compose up -d` from this
# directory. The .env file is gitignored — never commit local credentials.
#
# Production credentials live in Coolify (set via its admin UI, encrypted at
# rest in /data/coolify). These values apply ONLY to local development.

# --- Postgres ---
# Local dev uses 'postgres' / 'postgres' for convenience. The Postgres init
# script creates separate databases per service (platform, directus,
# authentik, listmonk) all owned by this user.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres

# --- MinIO ---
# Local dev uses minioadmin/minioadmin. Production picks long random values
# in Coolify. The values must satisfy MinIO's >=8 char minimum.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# --- Authentik (OIDC identity provider) ---
# Generate AUTHENTIK_SECRET_KEY locally and never reuse — at least 50 random
# chars. Recommended:
#   openssl rand -base64 60 | tr -d '\n'
# Generate AUTHENTIK_BOOTSTRAP_PASSWORD the same way (>=32 chars). This is the
# initial password for the `akadmin` user on first boot. After first login,
# change it via the admin UI; the env var is only read while no admin exists.
# AUTHENTIK_BOOTSTRAP_EMAIL receives password-reset / verification mail Authentik
# sends to itself (defaults to admin@aiqadam.org which forwards to the operator
# Gmail via Cloudflare Email Routing).
AUTHENTIK_SECRET_KEY=
AUTHENTIK_BOOTSTRAP_PASSWORD=
# AUTHENTIK_BOOTSTRAP_EMAIL=admin@aiqadam.org

# --- Host port overrides ---
# Defaults shown. Uncomment + change if you have local services on the same
# ports (e.g. you already run a Postgres on 5432 outside Docker).
# Apps on the host should connect using whichever port you set here.
# POSTGRES_HOST_PORT=5432
# REDIS_HOST_PORT=6379
# MINIO_API_HOST_PORT=9100
# MINIO_CONSOLE_HOST_PORT=9001
# AUTHENTIK_HOST_PORT=9000
