# infrastructure/.env.example
#
# Copy this file to infrastructure/.env, then `docker compose up -d` from this
# directory. The .env file is gitignored — never commit local credentials.
#
# Production credentials live in Coolify (set via its admin UI, encrypted at
# rest in /data/coolify). These values apply ONLY to local development.

# --- Postgres ---
# Local dev uses 'postgres' / 'postgres' for convenience. The Postgres init
# script creates separate databases per service (platform, directus,
# authentik, listmonk) all owned by this user.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres

# --- MinIO ---
# Local dev uses minioadmin/minioadmin. Production picks long random values
# in Coolify. The values must satisfy MinIO's >=8 char minimum.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# --- Authentik (OIDC identity provider) ---
# Generate AUTHENTIK_SECRET_KEY locally and never reuse — at least 50 random
# chars. Recommended:
#   openssl rand -base64 60 | tr -d '\n'
# Generate AUTHENTIK_BOOTSTRAP_PASSWORD the same way (>=32 chars). This is the
# initial password for the `akadmin` user on first boot. After first login,
# change it via the admin UI; the env var is only read while no admin exists.
# AUTHENTIK_BOOTSTRAP_EMAIL receives password-reset / verification mail Authentik
# sends to itself (defaults to admin@aiqadam.org which forwards to the operator
# Gmail via Cloudflare Email Routing).
AUTHENTIK_SECRET_KEY=
AUTHENTIK_BOOTSTRAP_PASSWORD=
# AUTHENTIK_BOOTSTRAP_EMAIL=admin@aiqadam.org

# --- Twenty CRM ---
# APP_SECRET: random 32+ char string used for JWT signing within Twenty.
# Generate: openssl rand -base64 32 | tr -d '\n'
# After first boot, visit http://localhost:3010 to create a workspace.
# Copy the resulting API key into apps/api/.env as TWENTY_API_KEY.
TWENTY_APP_SECRET=

# --- Directus CMS ---
# Local dev uses fixed known values (set via uat-env-setup.sh defaults).
# DIRECTUS_SECRET must be ≥32 chars; uat-env-setup.sh generates one if blank.
# ADMIN_TOKEN is the static service token the NestJS API uses to call Directus.
# In production, replace all three with secrets stored in Coolify.
DIRECTUS_ADMIN_EMAIL=admin@aiqadam.test
DIRECTUS_ADMIN_PASSWORD=SuperSecretPass
DIRECTUS_ADMIN_TOKEN=uat-directus-static-admin-token-32c
DIRECTUS_SECRET=

# --- Mailpit (local SMTP catcher) ---
# No credentials needed. Port defaults match uat-env-setup.sh.
# MAILPIT_UI_PORT=8025
# MAILPIT_SMTP_PORT=1025

# --- Telegram Bot API (local server) ---
# Obtain TELEGRAM_API_ID and TELEGRAM_API_HASH from https://my.telegram.org
# under "API development tools". These are app-level credentials (not the bot
# token). The bot token goes in apps/bot/.env as TELEGRAM_BOT_TOKEN.
# The bot must also set: TELEGRAM_LOCAL=true, TELEGRAM_API_SERVER=http://localhost:8082
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# --- Host port overrides ---
# Defaults shown. Uncomment + change if you have local services on the same
# ports. Check `docker ps` for conflicts before starting.
# Known occupied on this host (other projects): 5432, 5433, 5442, 8080, 8081, 1025, 80
# Apps on the host should connect using whichever port you set here.
# POSTGRES_HOST_PORT=5432
# REDIS_HOST_PORT=6379
# MINIO_API_HOST_PORT=9100
# MINIO_CONSOLE_HOST_PORT=9001
# AUTHENTIK_HOST_PORT=9000
# DIRECTUS_HOST_PORT=8200
# MAILPIT_UI_PORT=8025
# MAILPIT_SMTP_PORT=1025
# TWENTY_HOST_PORT=3010
# TELEGRAM_BOT_API_HOST_PORT=8082
